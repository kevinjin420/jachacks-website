        </div>

      </div>
    </section>
    <!-- GALLERY TEASER -->
    <section class="section" id="gallery">
      <div class="container">
        <div class="gallery-teaser reveal">
          <div class="gallery-teaser-photos">
            <div class="gt-photo gt-p1"><img src="/photos/DSC06792.webp" alt="" loading="lazy" /></div>
            <div class="gt-photo gt-p2"><img src="/photos/DSC06563.webp" alt="" loading="lazy" /></div>
            <div class="gt-photo gt-p3"><img src="/photos/DSC06646.webp" alt="" loading="lazy" /></div>
            <div class="gt-photo gt-p4"><img src="/photos/DSC06776.webp" alt="" loading="lazy" /></div>
            <div class="gt-overlay"></div>
          </div>
          <div class="gallery-teaser-content">
            <div class="section-eyebrow">// JACHACKS WINTER · GALLERY</div>
            <h2 class="section-title">Moments from <span class="text-accent">the Weekend</span></h2>
            <p class="section-sub">170+ hackers. 24 hours. One unforgettable weekend in Ann Arbor.</p>
            <a href="/gallery" class="btn-primary" style="margin-top:2rem; display:inline-flex;">
