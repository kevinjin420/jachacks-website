---
import '../styles/site.css';
---

<html lang="en">
  <head>
    <script is:inline>
      try { var t = localStorage.getItem('theme'); if (t === 'light') document.documentElement.setAttribute('data-theme','light'); } catch(e){}
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/jaseci-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JacHacks Winter · Winners</title>
    <meta name="description" content="JacHacks Winter 2026: winners, recap, and gallery from Ann Arbor." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&family=Rajdhani:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>

    <!-- NAV -->
    <nav id="main-nav" class="scrolled">
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/jaseci-logo.png" alt="JacHacks" class="logo-img" />
          <span class="logo-text">Jac<span class="logo-accent">Hacks</span></span>
        </a>
        <div class="nav-links">
          <a href="/" class="nav-link">// HOME</a>
          <a href="/spring" class="nav-link">// SPRING</a>
          <a href="/winter" class="nav-link">// WINTER</a>
          <a href="/paradise" class="nav-link">// VELRIC</a>
          <a href="/ohio" class="nav-link">// ROCKETHACKS</a>
          <a href="/gallery" class="nav-link">// GALLERY</a>
        </div>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark">
          <svg class="tt-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="tt-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href="https://github.com/jaseci-labs/jaseci" target="_blank" rel="noopener noreferrer" class="nav-cta">STAR ON GITHUB</a>
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/">// HOME</a>
      <a href="/spring">// SPRING</a>
      <a href="/winter">// WINTER</a>
      <a href="/paradise">// VELRIC</a>
      <a href="/ohio">// ROCKETHACKS</a>
      <a href="/gallery">// GALLERY</a>
      <a href="https://github.com/jaseci-labs/jaseci" target="_blank" class="mobile-cta">STAR ON GITHUB</a>
    </div>

    <main class="edition-main">
    <!-- JACHACKS WINTER BANNER -->
    <div class="v1-banner" id="winter">
      <div class="v1-banner-bg">
        <img src="/photos/DSC06792.webp" alt="JacHacks Winter" />
        <div class="v1-banner-overlay"></div>
      </div>
      <div class="v1-banner-content">
        <div class="v1-banner-tag">PREVIOUS EDITION</div>
        <div class="v1-banner-eyebrow">// APR 4–5, 2026 · ANN ARBOR, MI</div>
        <div class="v1-banner-title">JacHacks <span class="v1-banner-accent">Winter</span></div>
        <div class="v1-banner-sub">Where it all started.</div>
        <div class="v1-stats-row">
          <div class="v1-stat">
            <span class="v1-stat-val">170+</span>
            <span class="v1-stat-key">ATTENDEES</span>
          </div>
          <div class="v1-stat-sep">//</div>
          <div class="v1-stat">
            <span class="v1-stat-val">70</span>
            <span class="v1-stat-key">PROJECTS</span>
          </div>
          <div class="v1-stat-sep">//</div>
          <div class="v1-stat">
            <span class="v1-stat-val">24</span>
            <span class="v1-stat-key">HOURS</span>
          </div>
          <div class="v1-stat-sep">//</div>
          <div class="v1-stat">
            <span class="v1-stat-val">$5K</span>
            <span class="v1-stat-key">IN PRIZES</span>
          </div>
        </div>
      </div>
    </div>

    <!-- WINTER RECAP -->
    <section class="section recap-section" id="recap">
      <div class="container">
        <div class="recap-header reveal">
          <div class="section-eyebrow">// THE RECAP</div>
          <h2 class="section-title">Relive <span class="text-accent">JacHacks Winter</span></h2>
          <p class="section-sub">24 hours. 70 projects. One unforgettable weekend at U-M North Campus.</p>
        </div>
        <div class="recap-frame reveal">
          <span class="recap-corner recap-corner-tl"></span>
          <span class="recap-corner recap-corner-tr"></span>
          <span class="recap-corner recap-corner-bl"></span>
          <span class="recap-corner recap-corner-br"></span>
          <div class="recap-video">
            <span class="recap-rec"><span class="recap-rec-dot"></span> RECAP REEL</span>
            <iframe src="https://www.youtube.com/embed/zsqUxuRY5PI?rel=0" title="JacHacks Winter recap" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- WINNERS -->
    <section class="section section-dark" id="winners">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-eyebrow">// JACHACKS WINTER · WINNERS</div>
          <h2 class="section-title">The Best of <span class="text-accent">JacHacks Winter</span></h2>
          <p class="section-sub">The projects that stood out, built in 24 hours at U-M North Campus, April 2026.</p>
        </div>

        <!-- Agentic AI -->
        <div class="track-section">
          <div class="track-header">
            <span class="track-header-icon">//</span>
            <span class="track-label">Agentic AI Track</span>
            <span class="track-label-sub">2 WINNERS</span>
          </div>
          <div class="projects-grid projects-grid-2">
            <div class="pcard reveal"
              data-video="rAgFg8S8IJo"
              data-devpost="https://devpost.com/software/project-e54qlw07j9i1">
              <div class="pcard-bar bar-1st"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/534/388/datas/original.png" alt="GraphClaw" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges">
                  <span class="pbadge pbadge-1st">1ST PLACE</span>
                  <span class="pbadge pbadge-extra">BEST USE OF BASE44</span>
                </div>
                <h3 class="pcard-title">GraphClaw</h3>
                <p class="pcard-team">A K M Mahmudul Kabir, Abdullah Al Mahmud</p>
                <p class="pcard-desc">A multi-agent AI platform where memory lives in a property graph, agents are graph walkers, and skills can be installed from the internet at runtime.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/project-e54qlw07j9i1" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>

            <div class="pcard reveal delay-1"
              data-video="ZN0UVnNUpRs"
              data-video-start="2"
              data-devpost="https://devpost.com/software/ghostwatch">
              <div class="pcard-bar bar-2nd"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/533/420/datas/gallery.jpg" alt="GhostWatch" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-2nd">2ND PLACE</span></div>
                <h3 class="pcard-title">GhostWatch</h3>
                <p class="pcard-team">Aaron Sun, Ayush Madhav Kumar</p>
                <p class="pcard-desc">Autonomous code defense with graph-native clarity. Monitors repositories for risky dependency changes and PR signals, with automated sandboxed testing and optional fix generation.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/ghostwatch" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Fintech -->
        <div class="track-section">
          <div class="track-header">
            <span class="track-header-icon">//</span>
            <span class="track-label">Fintech Track</span>
            <span class="track-label-sub">2 WINNERS</span>
          </div>
          <div class="projects-grid projects-grid-2">
            <div class="pcard reveal"
              data-video=""
              data-devpost="https://devpost.com/software/polywatch">
              <div class="pcard-bar bar-1st"></div>
              <div class="pcard-thumb pcard-thumb-empty">
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-1st">1ST PLACE</span></div>
                <h3 class="pcard-title">PolyWatch</h3>
                <p class="pcard-team">Adam Christley, Caeden Kidd, Amar Zecevic, Schultz</p>
                <p class="pcard-desc">AI powered insider trading detection for prediction markets. Uses Tree of Thought reasoning to autonomously investigate manipulation, coordinated wallets, and suspicious trading patterns.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/polywatch" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>

            <div class="pcard reveal delay-1"
              data-video="6xC28FnsD9Y"
              data-devpost="https://devpost.com/software/sybilscope">
              <div class="pcard-bar bar-2nd"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/534/307/datas/gallery.jpg" alt="SybilScope" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-2nd">2ND PLACE</span></div>
                <h3 class="pcard-title">SybilScope</h3>
                <p class="pcard-team">David Chong, Yanshengtian Dong, Shrimann Myneni</p>
                <p class="pcard-desc">Detects fake wallet clusters in crypto airdrops using Jac's native graph Walker and AI reasoning. Builds a live wallet graph to distinguish coordinated fraud from legitimate activity.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/sybilscope" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Social Impact -->
        <div class="track-section">
          <div class="track-header">
            <span class="track-header-icon">//</span>
            <span class="track-label">Social Impact Track</span>
            <span class="track-label-sub">2 WINNERS</span>
          </div>
          <div class="projects-grid projects-grid-2">
            <div class="pcard reveal"
              data-video="SeP5gTAS4j0"
              data-video-start="1"
              data-devpost="https://devpost.com/software/hijac">
              <div class="pcard-bar bar-1st"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/533/977/datas/gallery.jpg" alt="Hijac" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-1st">1ST PLACE</span></div>
                <h3 class="pcard-title">Hijac</h3>
                <p class="pcard-team">Meron Demissie, Nitin Shankar Madhu, Chuka Ezeoke</p>
                <p class="pcard-desc">An AI-powered mobile agent that hijacks your routine. Monitors device sensors and automatically performs contextual actions based on detected patterns and user-defined rules.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/hijac" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>

            <div class="pcard reveal delay-1"
              data-video="nxqcHtGdQfo"
              data-devpost="https://devpost.com/software/jac-in-the-block">
              <div class="pcard-bar bar-2nd"></div>
              <div class="pcard-thumb pcard-thumb-empty">
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-2nd">2ND PLACE</span></div>
                <h3 class="pcard-title">Jac in the Block</h3>
                <p class="pcard-team">Krish Deshmukh, Kuldeep Debnath, Junna Park, Adam</p>
                <p class="pcard-desc">An accessible learning toolkit for Jac combining a block-based visual interface, real-time graph visualization, and a VS Code Extension Suite with linting and debugging support.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/jac-in-the-block" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Special Awards -->
        <div class="track-section">
          <div class="track-header">
            <span class="track-header-icon">//</span>
            <span class="track-label">Sponsor &amp; Special Awards</span>
            <span class="track-label-sub">4 WINNERS</span>
          </div>
          <div class="projects-grid projects-grid-3">
            <div class="pcard reveal"
              data-video="R1tjGuE_HS8"
              data-video-start="2"
              data-devpost="https://devpost.com/software/npm-supply-chain-risk-analyzer">
              <div class="pcard-bar bar-award"></div>
              <div class="pcard-thumb">
                <img src="https://img.youtube.com/vi/R1tjGuE_HS8/maxresdefault.jpg" alt="ChainViz demo" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-award">BEST USE OF JAC</span></div>
                <h3 class="pcard-title">ChainViz</h3>
                <p class="pcard-team">Darsh Poddar</p>
                <p class="pcard-desc">3D visualization of npm's single points of failure, with autonomous Jac agents that investigate any package's blast radius in real time across 217K+ vulnerability records.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/npm-supply-chain-risk-analyzer" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>

            <div class="pcard reveal delay-1"
              data-video="dFl09zi6uoQ"
              data-devpost="https://devpost.com/software/6th-sense-5cfry8">
              <div class="pcard-bar bar-award"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/534/228/datas/gallery.jpg" alt="6th Sense" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-award">BEST USE OF LOVABLE</span></div>
                <h3 class="pcard-title">6th Sense</h3>
                <p class="pcard-team">Raj, Adwayan Goswami, Aryan Singh, Param Natu</p>
                <p class="pcard-desc">A real-time AI assistant that listens, reads social cues, and suggests what to say instantly, for interviews, networking, and high-pressure conversations.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/6th-sense-5cfry8" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>

            <div class="pcard reveal delay-2"
              data-video="iwCxhwj_zYk"
              data-devpost="https://devpost.com/software/corpus-43v970">
              <div class="pcard-bar bar-award"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/533/924/datas/gallery.jpg" alt="Corpus" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-award">BEST USE OF INSFORGE + BACKBOARD</span></div>
                <h3 class="pcard-title">Corpus</h3>
                <p class="pcard-team">Anirudh Manjesh</p>
                <p class="pcard-desc">Your codebase has an immune system. Corpus watches AI-generated code, catches breakage before it lands, and self-heals your project against your codebase graph.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/corpus-43v970" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
              </div>
            </div>

            <div class="pcard reveal delay-3"
              data-video=""
              data-devpost="https://devpost.com/software/inocula-weaponize-the-trust-graph-then-inoculate-it">
              <div class="pcard-bar bar-award"></div>
              <div class="pcard-thumb">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/534/234/datas/gallery.jpg" alt="Inocula" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
