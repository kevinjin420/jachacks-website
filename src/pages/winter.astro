              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- VIDEO MODAL -->
    <div class="vm-backdrop" id="vm-backdrop"></div>
    <div class="vm" id="vm">
      <div class="vm-shell">
        <span class="vm-caption">// PROJECT DEMO</span>
        <button class="vm-close" id="vm-close" aria-label="Close video">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <div class="vm-body">
          <iframe id="vm-iframe" src="" title="Project demo video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
    </div>

    </main>

    <!-- FOOTER -->
    <footer>
      <div class="footer-top">
        <div class="footer-logo">
          <img src="/jaseci-logo.png" alt="Jaseci" class="logo-img" />
          <span>Jac<span class="text-accent">Hacks</span></span>
        </div>
        <div class="footer-nav">
          <a href="/spring">JacHacks Spring</a>
          <a href="/winter">JacHacks Winter</a>
          <a href="/paradise">Popup in Paradise</a>
          <a href="/ohio">Popup in Ohio</a>
          <a href="/gallery">Gallery</a>
        </div>
        <div class="footer-socials">
          <a href="https://x.com/Jaseci_Org" class="social-btn" aria-label="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.instagram.com/jaseci.ai/" target="_blank" class="social-btn" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/jaseci-labs/posts/?feedView=all" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7H10v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 JacHacks · Powered by <a href="https://jaseci.org" target="_blank" rel="noopener noreferrer">Jaseci</a> · A global hackathon series</p>
      </div>
    </footer>


  <script>
    // ===== REVEAL =====
    const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('revealed');obs.unobserve(e.target);}});},{threshold:.08,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

    // ===== NAV =====
    const nav=document.getElementById('main-nav')!;
    window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',window.scrollY>60));

    // ===== HAMBURGER =====
    const hbg=document.getElementById('hamburger')!,mm=document.getElementById('mobile-menu')!;
    hbg.addEventListener('click',()=>{hbg.classList.toggle('open');mm.classList.toggle('open');});
    mm.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{hbg.classList.remove('open');mm.classList.remove('open');}));

    // ===== THEME TOGGLE =====
    const themeBtn = document.getElementById('theme-toggle')!;
    themeBtn.addEventListener('click', () => {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if (isLight) {
        document.documentElement.removeAttribute('data-theme');
        try { localStorage.setItem('theme','dark'); } catch(e){}
      } else {
        document.documentElement.setAttribute('data-theme','light');
        try { localStorage.setItem('theme','light'); } catch(e){}
      }
    });

    // ===== TEAM AVATARS =====
    function getInitials(name: string): string {
      const cleaned = name.replace(/\./g, '').trim();
      const parts = cleaned.split(/\s+/).filter(p => p.length > 0);
      if (parts.length === 0) return '?';
      if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
      return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
    }
    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    document.querySelectorAll<HTMLElement>('.pcard-team').forEach(el => {
      const text = (el.textContent || '').trim();
      if (!text) return;
      const names = text.split(/,\s*/).map(n => n.trim()).filter(n => n.length > 0);
      if (names.length === 0) return;
      // Preserve Astro's scoped style attribute on dynamically created children
      const cidAttr = el.getAttributeNames().find(n => n.startsWith('data-astro-cid-'));
      const cidStr = cidAttr ? ` ${cidAttr}=""` : '';
      el.innerHTML = `<span class="team-label"${cidStr}>TEAM</span>` +
        names.map(n => `<span class="team-avatar"${cidStr} data-name="${escapeHtml(n)}">${escapeHtml(getInitials(n))}</span>`).join('');
    });

    // ===== VIDEO MODAL =====
    const vmBackdrop = document.getElementById('vm-backdrop')!;
    const vm = document.getElementById('vm')!;
    const vmIframe = document.getElementById('vm-iframe') as HTMLIFrameElement;
    const vmClose = document.getElementById('vm-close')!;

    function openVideo(youtubeId: string, startSeconds?: string) {
      const start = startSeconds && startSeconds.length > 0 ? `&start=${startSeconds}` : '';
      vmIframe.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0${start}`;
      vm.classList.add('open');
      vmBackdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeVideo() {
      vm.classList.remove('open');
      vmBackdrop.classList.remove('open');
      vmIframe.src = '';
      document.body.style.overflow = '';
    }

    function handleProjectClick(card: HTMLElement) {
      const videoId = card.dataset.video;
      const videoStart = card.dataset.videoStart;
      const devpost = card.dataset.devpost;
      if (videoId && videoId.length > 0) {
        openVideo(videoId, videoStart);
      } else if (devpost) {
        window.open(devpost, '_blank', 'noopener,noreferrer');
      }
    }

    document.querySelectorAll<HTMLElement>('.js-demo').forEach(el => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = el.closest<HTMLElement>('[data-devpost]');
        if (card) handleProjectClick(card);
      });
    });

    document.querySelectorAll<HTMLElement>('.pcard-thumb').forEach(thumb => {
      thumb.addEventListener('click', () => {
        const card = thumb.closest<HTMLElement>('[data-devpost]');
        if (card) handleProjectClick(card);
      });
    });

    vmClose.addEventListener('click', closeVideo);
    vmBackdrop.addEventListener('click', closeVideo);
    vm.addEventListener('click', e => { if (e.target === vm) closeVideo(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && vm.classList.contains('open')) closeVideo(); });
  </script>
  </body>
</html>
