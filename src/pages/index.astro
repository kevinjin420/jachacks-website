<html lang="en">
  <head>
    <script is:inline>
      try { var t = localStorage.getItem('theme'); if (t === 'light') document.documentElement.setAttribute('data-theme','light'); } catch(e){}
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/jaseci-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JacHacks · Hackathon Series</title>
    <meta name="description" content="JacHacks SF: a one-day, in-person hackathon for the Bay Area tech community. July 26, 2026, Founders, Inc., San Francisco." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://jachacks.org/" />
    <meta property="og:title" content="JacHacks SF · In-Person Hackathon" />
    <meta property="og:description" content="One day. In person. Build the future with Jac. July 26, 2026, Founders, Inc., San Francisco." />
    <meta property="og:image" content="https://jachacks.org/jaseci-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
