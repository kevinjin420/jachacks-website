          <a class="strip-logo" href="https://wip.com" target="_blank" rel="noopener noreferrer"><img src="/sponsors/wip.png" alt="WIP" /></a>
          <a class="strip-logo" href="https://insforge.dev" target="_blank" rel="noopener noreferrer"><img src="/sponsors/insforge.png" alt="Insforge" /></a>
          <a class="strip-logo" href="https://lovable.dev" target="_blank" rel="noopener noreferrer"><img src="/sponsors/lovable.svg" alt="Lovable" /></a>
          <a class="strip-logo" href="https://openai.com/codex/" target="_blank" rel="noopener noreferrer"><img src="/sponsors/codex.png" alt="Codex" /></a>
          <a class="strip-logo" href="https://velric.ai" target="_blank" rel="noopener noreferrer"><img src="/sponsors/velric.png" alt="Velric" class="velric-lg" /></a>
          <a class="strip-logo" href="https://backboard.io" target="_blank" rel="noopener noreferrer"><img src="/sponsors/backboard.png" alt="Backboard" /></a>
