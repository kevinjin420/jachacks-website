  <script>
    // ===== CANVAS =====
    const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const OR = 'rgba(249,115,22,';
    const CY = 'rgba(0,212,255,';

    function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
    resize();
    window.addEventListener('resize', resize);

    const N = 35;
    interface GNode { x:number;y:number;vx:number;vy:number;r:number;cyan:boolean; }
    interface Walker { fi:number;ti:number;t:number;sp:number; }
    interface Particle { x:number;y:number;vx:number;vy:number;a:number;sz:number;life:number;ml:number; }

    const nodes: GNode[] = Array.from({length:N}, () => ({
      x: Math.random()*canvas.width, y: Math.random()*canvas.height,
      vx: (Math.random()-.5)*.3, vy: (Math.random()-.5)*.3,
      r: Math.random()*2+1.5, cyan: Math.random()<.22
    }));
    const walkers: Walker[] = Array.from({length:6}, () => ({
      fi: Math.floor(Math.random()*N), ti: Math.floor(Math.random()*N), t:0, sp:.005+Math.random()*.004
    }));
    const parts: Particle[] = [];
    function sp(): Particle {
      return {x:Math.random()*canvas.width,y:canvas.height+10,vx:(Math.random()-.5)*.4,vy:-(0.3+Math.random()*.5),a:.4+Math.random()*.4,sz:Math.random()*1.5+.5,life:0,ml:200+Math.random()*200};
    }
    for(let i=0;i<60;i++){const p=sp();p.y=Math.random()*canvas.height;p.life=Math.random()*p.ml;parts.push(p);}

    const ED=220;
    function draw(){
      const W=canvas.width,H=canvas.height;
      ctx.clearRect(0,0,W,H);
      for(const n of nodes){n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1;}
      for(let i=0;i<nodes.length;i++){
        for(let j=i+1;j<nodes.length;j++){
          const dx=nodes[i].x-nodes[j].x,dy=nodes[i].y-nodes[j].y,d=Math.sqrt(dx*dx+dy*dy);
          if(d<ED){
            const a=(1-d/ED)*.15;
            const c=nodes[i].cyan&&nodes[j].cyan?CY:OR;
            ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);
            ctx.strokeStyle=`${c}${a})`;ctx.lineWidth=.8;ctx.stroke();
          }
        }
      }
      for(const n of nodes){
        ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);
        ctx.fillStyle=n.cyan?`${CY}.45)`:`${OR}.4)`;ctx.fill();
      }
      for(const w of walkers){
        w.t+=w.sp;
        if(w.t>=1){
          w.fi=w.ti;
          const from=nodes[w.fi];let best=-1,bd=Infinity;
          for(let i=0;i<N;i++){if(i===w.fi)continue;const dx=from.x-nodes[i].x,dy=from.y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);if(d<ED&&d<bd){bd=d;best=i;}}
          w.ti=best===-1?Math.floor(Math.random()*N):best;w.t=0;
        }
        const f=nodes[w.fi],t=nodes[w.ti];
        const wx=f.x+(t.x-f.x)*w.t,wy=f.y+(t.y-f.y)*w.t;
        const c=nodes[w.fi].cyan?CY:OR;
        const g=ctx.createRadialGradient(wx,wy,0,wx,wy,12);
        g.addColorStop(0,`${c}.85)`);g.addColorStop(1,`${c}0)`);
        ctx.beginPath();ctx.arc(wx,wy,12,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
        ctx.beginPath();ctx.arc(wx,wy,2.5,0,Math.PI*2);ctx.fillStyle=`${c}1)`;ctx.fill();
      }
      if(Math.random()<.3)parts.push(sp());
      for(let i=parts.length-1;i>=0;i--){
        const p=parts[i];p.x+=p.vx;p.y+=p.vy;p.life++;
        const fade=Math.min(p.life/30,1)*Math.max(1-p.life/p.ml,0);
        ctx.beginPath();ctx.arc(p.x,p.y,p.sz,0,Math.PI*2);
        ctx.fillStyle=`${OR}${p.a*fade})`;ctx.fill();
        if(p.life>=p.ml)parts.splice(i,1);
      }
      requestAnimationFrame(draw);
    }
    draw();

    // ===== COUNTDOWN =====
    (function() {
      const target = new Date('2026-05-15T00:00:00').getTime();
      const days = document.getElementById('cd-days')!;
      const hours = document.getElementById('cd-hours')!;
      const mins = document.getElementById('cd-mins')!;
      const secs = document.getElementById('cd-secs')!;
      function pad(n: number){ return String(n).padStart(2,'0'); }
      function tick(){
        const diff = target - Date.now();
        if(diff <= 0){ days.textContent=hours.textContent=mins.textContent=secs.textContent='00'; return; }
        days.textContent  = pad(Math.floor(diff/86400000));
        hours.textContent = pad(Math.floor((diff%86400000)/3600000));
        mins.textContent  = pad(Math.floor((diff%3600000)/60000));
        secs.textContent  = pad(Math.floor((diff%60000)/1000));
      }
      tick();
      setInterval(tick, 1000);
    })();

    // ===== REVEAL =====
    const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('revealed');obs.unobserve(e.target);}});},{threshold:.08,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

    // ===== NAV =====
    const nav=document.getElementById('main-nav')!;
    window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',window.scrollY>60));

    // ===== HAMBURGER =====
    const hbg=document.getElementById('hamburger')!,mm=document.getElementById('mobile-menu')!;
    hbg.addEventListener('click',()=>{hbg.classList.toggle('open');mm.classList.toggle('open');});
    mm.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{hbg.classList.remove('open');mm.classList.remove('open');}));
  </script>
  </body>
