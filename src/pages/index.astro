<html lang="en">
  <head>
    <script is:inline>
      try { var t = localStorage.getItem('theme'); if (t === 'light') document.documentElement.setAttribute('data-theme','light'); } catch(e){}
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/jaseci-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JacHacks — Hackathon Series</title>
    <meta name="description" content="JacHacks Spring — a global online 48-hour hackathon. Build AI-native apps with Jac. May 15–17, 2026." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://jachacks.org/" />
    <meta property="og:title" content="JacHacks Spring — Global Online Hackathon" />
    <meta property="og:description" content="48 hours. Global. Online. Build the future with Jac. May 15–17, 2026." />
    <meta property="og:image" content="https://jachacks.org/jaseci-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&family=Rajdhani:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>

    <!-- NAV -->
    <nav id="main-nav">
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/jaseci-logo.png" alt="JacHacks" class="logo-img" />
          <span class="logo-text">Jac<span class="logo-accent">Hacks</span></span>
        </a>
        <div class="nav-links">
          <a href="#spring" class="nav-link">// SPRING</a>
          <a href="#winter" class="nav-link">// JACHACKS WINTER</a>
          <a href="/gallery" class="nav-link">// GALLERY</a>
        </div>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark">
          <svg class="tt-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="tt-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href="https://github.com/jaseci-labs/jaseci" target="_blank" rel="noopener noreferrer" class="nav-cta">STAR ON GITHUB</a>
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="#spring">// SPRING</a>
      <a href="#winter">// JACHACKS WINTER</a>
      <a href="/gallery">// GALLERY</a>
      <a href="https://github.com/jaseci-labs/jaseci" target="_blank" class="mobile-cta">STAR ON GITHUB</a>
    </div>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-grid-bg"></div>
      <canvas id="bg-canvas"></canvas>

      <div class="hud-tl">
        <span class="hud-label">SYS://GLOBAL_ONLINE</span>
      </div>
      <div class="hud-tr">
        <span class="hud-label hud-label-white">EVENT://MAY_15-17_2026</span>
      </div>
      <div class="hud-bl">
        <span class="hud-label">DURATION: <span class="hud-count">048HRS</span></span>
      </div>
      <div class="hud-br">
        <span class="hud-label hud-label-accent">FORMAT://ONLINE_WORLDWIDE</span>
      </div>

      <div class="float-el fe-hex-1">
        <svg viewBox="0 0 60 69" width="60" height="69" fill="none">
          <polygon points="30,3 57,18 57,51 30,66 3,51 3,18" stroke="rgba(249,115,22,0.3)" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="float-el fe-hex-2">
        <svg viewBox="0 0 40 46" width="40" height="46" fill="none">
          <polygon points="20,2 38,12 38,34 20,44 2,34 2,12" stroke="rgba(0,212,255,0.25)" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="float-el fe-hex-3">
        <svg viewBox="0 0 90 104" width="90" height="104" fill="none">
          <polygon points="45,4 86,27 86,77 45,100 4,77 4,27" stroke="rgba(249,115,22,0.1)" stroke-width="1"/>
        </svg>
      </div>
      <div class="float-el fe-plus-1">+</div>
      <div class="float-el fe-plus-2">+</div>
      <div class="float-el fe-plus-3">×</div>
      <div class="float-el fe-ring-1"></div>
      <div class="float-el fe-ring-2"></div>
      <div class="float-el fe-ring-3"></div>

      <div class="hero-spotlight"></div>

      <div class="hero-content">
        <div class="hero-series-badge">
          <span class="series-dot"></span>
          <span>JACHACKS SERIES</span>
          <span class="series-sep">·</span>
          <span class="series-event">SPRING 2026</span>
        </div>

        <div class="hero-title">
          <img src="/jaseci-logo.png" alt="" class="hero-j-logo" />
          <h1 class="title-main">JacHacks <span class="title-spring">Spring</span></h1>
        </div>

        <p class="hero-sub">A global 48-hour hackathon.<br />Build AI-native apps with Jac — from anywhere on the planet.</p>

        <div class="hero-meta-line">
          <span>MAY 15–17, 2026</span>
          <span class="meta-dot">·</span>
          <span>48 HOURS</span>
          <span class="meta-dot">·</span>
          <span>GLOBAL ONLINE</span>
        </div>

        <div class="countdown" id="countdown">
          <div class="cd-block">
            <span class="cd-val" id="cd-days">00</span>
            <span class="cd-label">DAYS</span>
          </div>
          <span class="cd-sep">:</span>
          <div class="cd-block">
            <span class="cd-val" id="cd-hours">00</span>
            <span class="cd-label">HRS</span>
          </div>
          <span class="cd-sep">:</span>
          <div class="cd-block">
            <span class="cd-val" id="cd-mins">00</span>
            <span class="cd-label">MIN</span>
          </div>
          <span class="cd-sep">:</span>
          <div class="cd-block">
            <span class="cd-val" id="cd-secs">00</span>
            <span class="cd-label">SEC</span>
          </div>
        </div>

        <div class="cta-group">
          <div class="btn-coming-soon">
            <span class="cs-dot"></span>
            REGISTRATION COMING SOON
          </div>
          <a href="#winter" class="btn-ghost">
            SEE JACHACKS WINTER
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
        </div>
      </div>

      <div class="scroll-down">
        <span>SCROLL</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </div>
    </section>

    <!-- SPRING EVENT DETAILS -->
    <section class="section section-spring" id="spring">
      <div class="container">
        <div class="spring-header reveal">
          <div class="spring-header-left">
            <div class="section-eyebrow">// JACHACKS SPRING 2026</div>
            <h2 class="section-title">The Next Chapter.<br /><span class="text-accent">Worldwide.</span></h2>
          </div>
          <p class="spring-header-right">JacHacks is going global. Same energy, same Jac language, no zip code required. Join hackers from around the world for 48 hours of building.</p>
        </div>

        <div class="spring-grid">
          <div class="spring-card reveal">
            <div class="spring-card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div class="spring-card-title">Global & Online</div>
            <p class="spring-card-desc">Open to builders everywhere — no travel required. Hack from your dorm, home, or anywhere with Wi-Fi.</p>
          </div>

          <div class="spring-card reveal delay-1">
            <div class="spring-card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="spring-card-title">48 Hours</div>
            <p class="spring-card-desc">Non-stop building across May 15–17, 2026. From kickoff to demo — two full days of shipping.</p>
          </div>

          <div class="spring-card reveal delay-2">
            <div class="spring-card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <div class="spring-card-title">Build with Jac</div>
            <p class="spring-card-desc">Use the Jac language to build AI-native, graph-powered applications. Tutorials and mentors included.</p>
          </div>

          <div class="spring-card reveal delay-3">
            <div class="spring-card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <div class="spring-card-title">Prizes & Recognition</div>
            <p class="spring-card-desc">Win prizes across multiple tracks — agentic AI, fintech, social impact, and more. Details dropping soon.</p>
          </div>
        </div>

        <div class="spring-notify reveal">
          <div class="notify-inner">
            <div class="notify-badge">
              <span class="notify-dot"></span>
              REGISTRATION OPENING SOON
            </div>
            <p class="notify-text">Be the first to know when registration goes live.</p>
            <div class="notify-actions">
              <a href="https://github.com/jaseci-labs/jaseci" target="_blank" rel="noopener noreferrer" class="btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
                STAR ON GITHUB
              </a>
              <a href="https://x.com/Jaseci_Org" target="_blank" rel="noopener noreferrer" class="btn-ghost">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                FOLLOW FOR UPDATES
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PLATINUM SPONSOR -->
    <div class="platinum-sponsor reveal">
      <span class="platinum-label">POWERED BY</span>
      <a href="https://jaseci.org" target="_blank" rel="noopener noreferrer" class="platinum-link">
        <img src="/jaseci-logo.png" alt="Jaseci" class="platinum-logo" />
      </a>
      <p class="platinum-desc">Powering the future of AI programming</p>
    </div>

    <!-- SPONSOR STRIP -->
    <div class="sponsor-strip">
      <span class="strip-label">JACHACKS WINTER SPONSORS</span>
      <div class="strip-marquee">
        <div class="strip-track">
