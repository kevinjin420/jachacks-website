  .spring-card::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg, rgba(249,115,22,.04) 0%, transparent 60%); pointer-events:none; }
  .spring-card:hover { transform:translateY(-5px); border-color:rgba(249,115,22,.25); box-shadow:0 12px 40px rgba(0,0,0,.4), 0 0 30px rgba(249,115,22,.07); }
  .spring-card-icon { width:52px; height:52px; border-radius:10px; background:rgba(249,115,22,.08); border:1px solid rgba(249,115,22,.15); display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0; }
  .spring-card-title { font-family:var(--display); font-weight:700; font-size:1.15rem; letter-spacing:.04em; color:#fff; }
  .spring-card-desc { font-size:.875rem; color:var(--light); line-height:1.68; }

  .spring-notify { background: linear-gradient(135deg, rgba(249,115,22,.07) 0%, rgba(168,85,247,.04) 100%); border: 1px solid rgba(249,115,22,.2); border-radius:14px; overflow:hidden; position:relative; }
  .spring-notify::before { content:''; position:absolute; inset:0; background: repeating-linear-gradient(90deg, rgba(249,115,22,.03) 0px, rgba(249,115,22,.03) 1px, transparent 1px, transparent 60px); pointer-events:none; }
  .notify-inner { position:relative; padding:3.5rem 3rem; display:flex; flex-direction:column; align-items:center; gap:1.25rem; text-align:center; }
  .notify-badge { display:inline-flex; align-items:center; gap:.6rem; font-family:var(--mono); font-size:.65rem; letter-spacing:.2em; color:var(--green); background:rgba(34,197,94,.08); border:1px solid rgba(34,197,94,.25); padding:.45rem 1.2rem; border-radius:100px; }
  .notify-dot { width:6px; height:6px; border-radius:50%; background:var(--green); box-shadow:0 0 8px var(--green); animation:blink 1.8s ease-in-out infinite; }
  .notify-text { font-family:var(--display); font-weight:600; font-size:1.25rem; color:var(--light); letter-spacing:.03em; }
  .notify-actions { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-top:.5rem; }

  /* ── VIDEO MODAL ── */
  .vm-backdrop { position:fixed; inset:0; background:rgba(4,3,10,.85); z-index:300; opacity:0; pointer-events:none; transition:opacity .35s ease; backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); }
  .vm-backdrop.open { opacity:1; pointer-events:all; }
  .vm { position:fixed; inset:0; z-index:301; display:flex; align-items:center; justify-content:center; padding:2.5rem; opacity:0; pointer-events:none; transition:opacity .35s ease; }
  .vm.open { opacity:1; pointer-events:all; }
