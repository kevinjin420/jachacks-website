  .vm.open .vm-shell { transform:scale(1); }
  .vm-body { width:100%; aspect-ratio:16/9; border-radius:14px; overflow:hidden; box-shadow:0 40px 120px rgba(0,0,0,.7), 0 0 50px rgba(249,115,22,.12), 0 0 0 1px rgba(255,255,255,.08); background:#000; position:relative; }
  .vm-body iframe { width:100%; height:100%; border:none; display:block; }
  .vm-close { position:absolute; top:-3.25rem; right:0; width:40px; height:40px; border-radius:50%; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.18); color:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background .2s, border-color .2s, transform .2s; backdrop-filter:blur(8px); }
  .vm-close:hover { background:rgba(249,115,22,.3); border-color:rgba(249,115,22,.5); transform:rotate(90deg); }
  .vm-caption { position:absolute; top:-3rem; left:0; font-family:var(--mono); font-size:.6rem; letter-spacing:.28em; color:rgba(255,255,255,.5); text-transform:uppercase; }
  @media (max-width:768px) {
    .vm { padding:1rem; }
    .vm-close { top:-2.5rem; width:34px; height:34px; }
    .vm-caption { display:none; }
  }

  /* ── PLATINUM SPONSOR ── */
  .platinum-sponsor { display: flex; flex-direction: column; align-items: center; gap: 1.25rem; padding: 5rem 2rem; background: radial-gradient(circle at center, rgba(249,115,22,.07) 0%, transparent 70%); position: relative; z-index: 1; }
  .platinum-label { font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.4em; color: var(--primary); opacity: 0.75; }
  .platinum-logo { height: 90px; width: auto; filter: drop-shadow(0 0 28px rgba(249,115,22,.35)); transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease; }
  .platinum-link:hover .platinum-logo { transform: scale(1.08); filter: drop-shadow(0 0 45px rgba(249,115,22,.55)); }
  .platinum-desc { font-family: var(--display); font-weight: 500; font-size: 1.15rem; color: var(--light); letter-spacing: 0.05em; opacity: 0.8; max-width: 400px; text-align: center; line-height: 1.4; }

  /* ── SPONSOR STRIP ── */
  .sponsor-strip { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 2rem 0; background: rgba(0,0,0,.2); border-top: 1px solid rgba(255,255,255,.05); border-bottom: 1px solid rgba(255,255,255,.05); position: relative; z-index: 1; overflow: hidden; }
  .strip-label { font-family: var(--mono); font-size: .6rem; letter-spacing: .3em; color: rgba(255,255,255,.65); white-space: nowrap; }
  .strip-marquee { width: 100%; overflow: hidden; }
  .strip-track { display: flex; align-items: center; width: max-content; animation: scroll 60s linear infinite; }
  .strip-track:hover { animation-play-state: paused; }
  .strip-logo { display: flex; align-items: center; justify-content: center; padding: 0 2.5rem; flex-shrink: 0; transition: opacity .2s; }
  .strip-logo:hover { opacity: .7; }
  .strip-logo img { height: 58px; max-width: 180px; width: auto; object-fit: contain; filter: brightness(.85) grayscale(.2); transition: filter .2s; }
  .strip-logo img.velric-lg { height: 58px; max-width: 180px; }
  .strip-logo:hover img { filter: brightness(1.1) grayscale(0); }
  @keyframes scroll { from{transform:translateX(0)} to{transform:translateX(-33.333%)} }

  /* ── V1 BANNER ── */
  .v1-banner { position:relative; z-index:1; min-height:420px; display:flex; align-items:center; justify-content:center; overflow:hidden; }
  .v1-banner-bg { position:absolute; inset:0; }
  .v1-banner-bg img { width:100%; height:100%; object-fit:cover; object-position:center 30%; display:block; }
  .v1-banner-overlay { position:absolute; inset:0; background: linear-gradient(to bottom, rgba(6,5,13,.55) 0%, rgba(6,5,13,.3) 40%, rgba(6,5,13,.8) 85%, rgba(6,5,13,1) 100%), linear-gradient(to right, rgba(6,5,13,.6) 0%, transparent 40%, transparent 60%, rgba(6,5,13,.6) 100%); }
  .v1-banner-content { position:relative; z-index:2; text-align:center; padding:5rem 2rem; display:flex; flex-direction:column; align-items:center; gap:1rem; }
  .v1-banner-eyebrow { font-family:var(--mono); font-size:.65rem; letter-spacing:.3em; color:rgba(249,115,22,.8); }
  .v1-banner-title { font-family:var(--serif); font-weight:800; font-size:clamp(3rem,8vw,6.5rem); color:#F3EBD7; letter-spacing:-.025em; line-height:1; }
  .v1-banner-accent { color:var(--primary); font-style:italic; }
  .v1-banner-sub { font-family:var(--display); font-weight:500; font-size:1.1rem; color:rgba(242,234,214,.65); letter-spacing:.04em; }
  .v1-stats-row { display:flex; align-items:center; gap:.5rem; margin-top:1.5rem; background:rgba(6,5,13,.5); border:1px solid rgba(249,115,22,.2); border-radius:10px; padding:.9rem 2rem; backdrop-filter:blur(12px); flex-wrap:wrap; justify-content:center; }
  .v1-stat { display:flex; flex-direction:column; align-items:center; padding:.2rem 1.5rem; gap:.15rem; }
  .v1-stat-val { font-family:var(--display); font-weight:700; font-size:1.9rem; letter-spacing:-.02em; color:var(--primary); line-height:1; }
  .v1-stat-key { font-family:var(--mono); font-size:.58rem; letter-spacing:.22em; color:rgba(255,255,255,.78); font-weight:500; }
  .v1-stat-sep { font-family:var(--mono); color:rgba(249,115,22,.25); font-size:.85rem; padding:0 .25rem; }

  /* ── RECAP VIDEO ── */
  .recap-section { padding-top:5rem; padding-bottom:5rem; }
  .recap-section::before { display:none; }
  .recap-header { text-align:center; margin-bottom:2.75rem; display:flex; flex-direction:column; align-items:center; gap:.6rem; }
  .recap-header .section-sub { margin:0 auto; }
  .recap-frame { position:relative; max-width:1040px; margin:0 auto; padding:14px; background:linear-gradient(135deg, rgba(249,115,22,.22) 0%, rgba(168,85,247,.16) 50%, rgba(0,212,255,.14) 100%); border-radius:18px; box-shadow:0 30px 90px rgba(0,0,0,.55), 0 0 70px rgba(249,115,22,.18); }
  .recap-frame::before { content:''; position:absolute; inset:0; border-radius:18px; padding:1px; background:linear-gradient(135deg, rgba(255,255,255,.18), rgba(255,255,255,0) 50%); -webkit-mask:linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite:xor; mask-composite:exclude; pointer-events:none; }
  .recap-video { position:relative; aspect-ratio:16/9; border-radius:11px; overflow:hidden; background:#000; box-shadow:inset 0 0 0 1px rgba(0,0,0,.4); }
  .recap-video iframe { position:absolute; inset:0; width:100%; height:100%; border:0; display:block; }
  .recap-rec { position:absolute; top:1rem; right:1rem; z-index:2; display:inline-flex; align-items:center; gap:.45rem; font-family:var(--mono); font-size:.6rem; letter-spacing:.22em; color:rgba(255,255,255,.95); background:rgba(0,0,0,.65); backdrop-filter:blur(8px); padding:.4rem .75rem; border-radius:4px; border:1px solid rgba(255,255,255,.14); pointer-events:none; }
  .recap-rec-dot { width:6px; height:6px; border-radius:50%; background:#ef4444; box-shadow:0 0 8px #ef4444; animation:rec-blink 1.4s ease-in-out infinite; }
  .recap-corner { position:absolute; width:26px; height:26px; pointer-events:none; z-index:3; }
  .recap-corner-tl { top:-8px; left:-8px; border-top:2px solid var(--primary); border-left:2px solid var(--primary); }
  .recap-corner-tr { top:-8px; right:-8px; border-top:2px solid var(--primary); border-right:2px solid var(--primary); }
  .recap-corner-bl { bottom:-8px; left:-8px; border-bottom:2px solid var(--primary); border-left:2px solid var(--primary); }
  .recap-corner-br { bottom:-8px; right:-8px; border-bottom:2px solid var(--primary); border-right:2px solid var(--primary); }
  @media (max-width:768px) {
    .recap-section { padding-top:3.5rem; padding-bottom:3.5rem; }
    .recap-frame { padding:10px; border-radius:14px; }
    .recap-corner { width:18px; height:18px; }
  }

  /* ── SECTIONS ── */
  .section { padding:7rem 2rem; position:relative; z-index:1; }
  .section::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(249,115,22,.18) 30%,rgba(249,115,22,.18) 70%,transparent); }
  .section-dark { background:linear-gradient(180deg,rgba(0,0,0,.25) 0%,transparent 100%); }
  .container { max-width:1200px; margin:0 auto; }
  .section-eyebrow { font-family:var(--mono); font-size:.68rem; font-weight:500; letter-spacing:.25em; color:var(--primary); margin-bottom:.75rem; }
  .section-title { font-family:var(--display); font-weight:700; font-size:clamp(2rem,5vw,3.5rem); letter-spacing:-.01em; color:#fff; margin-bottom:1rem; }
  .section-sub { color:var(--light); font-size:.97rem; line-height:1.68; max-width:600px; }
  .section-header { margin-bottom:4rem; }

  .reveal { opacity:0; transform:translateY(28px); transition:opacity .7s ease,transform .7s ease; will-change: transform, opacity; }
  .reveal.revealed { opacity:1; transform:translateY(0); }
  .delay-1 { transition-delay:.12s; }
  .delay-2 { transition-delay:.24s; }
  .delay-3 { transition-delay:.36s; }

  .corner { position:absolute; width:14px; height:14px; }
  .corner.tl { top:0; left:0; border-top:2px solid; border-left:2px solid; }
  .corner.tr { top:0; right:0; border-top:2px solid; border-right:2px solid; }
  .corner.bl { bottom:0; left:0; border-bottom:2px solid; border-left:2px solid; }
  .corner.br { bottom:0; right:0; border-bottom:2px solid; border-right:2px solid; }
  .kc-corners,.wc-corners { position:absolute; inset:0; pointer-events:none; z-index:2; }

  /* ── PROJECT CARDS (cinematic showcase) ── */
  .track-section { margin-bottom:5rem; }
  .track-header { display:flex; align-items:center; gap:1.1rem; margin-bottom:2rem; padding:.4rem 0 1rem; border-bottom:1px solid rgba(255,255,255,.06); position:relative; }
  .track-header::after { content:''; position:absolute; left:0; bottom:-1px; width:60px; height:1px; background:linear-gradient(90deg,var(--primary),transparent); }
  .track-grand { border-bottom-color:rgba(255,215,0,.18); }
  .track-grand::after { background:linear-gradient(90deg,#FFD700,transparent); width:120px; }
  .track-grand .track-header-icon { color:#FFD700; text-shadow:0 0 14px rgba(255,215,0,.5); }
  .track-header-icon { font-family:var(--mono); font-size:1rem; font-weight:600; color:var(--primary); flex-shrink:0; min-width:28px; }
  .track-label { font-family:var(--display); font-size:1.25rem; font-weight:700; letter-spacing:.04em; color:#fff; text-transform:uppercase; }
  .track-label-sub { font-family:var(--mono); font-size:.58rem; letter-spacing:.22em; color:var(--muted); margin-left:auto; padding:.3rem .7rem; border:1px solid var(--border); border-radius:100px; }

  .projects-grid { display:grid; gap:1.5rem; }
  .projects-grid-1 { grid-template-columns:1fr; }
  .projects-grid-2 { grid-template-columns:1fr 1fr; }
  .projects-grid-3 { grid-template-columns:repeat(3,1fr); }

  .pcard { background:linear-gradient(180deg,#1a1828 0%,#15131f 100%); border:1px solid rgba(255,255,255,.07); border-radius:14px; overflow:hidden; display:flex; flex-direction:column; transition:transform .3s ease, box-shadow .3s ease, border-color .3s ease; position:relative; box-shadow:0 4px 18px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.04); }
  .pcard > .pcard-bar    { order:0; }
  .pcard > .pcard-body   { order:1; }
  .pcard > .pcard-thumb  { order:2; }
  .pcard > .pcard-actions{ order:3; }
  .pcard:hover { transform:translateY(-6px); box-shadow:0 24px 60px rgba(0,0,0,.6), 0 0 30px rgba(249,115,22,.1), inset 0 1px 0 rgba(255,255,255,.06); border-color:rgba(249,115,22,.32); }
  .pcard-grand { flex-direction:row; background:linear-gradient(135deg,rgba(255,215,0,.04) 0%,rgba(20,18,32,.7) 40%,rgba(12,10,22,.8) 100%); border-color:rgba(255,215,0,.18); }
  .pcard-grand:hover { box-shadow:0 24px 70px rgba(0,0,0,.55), 0 0 50px rgba(255,215,0,.1); border-color:rgba(255,215,0,.4); }
  .pcard-grand .pcard-thumb { width:58%; flex-shrink:0; }
  .pcard-grand .pcard-body { flex:1; padding:2.5rem 2.25rem; }

  .pcard-bar { height:3px; flex-shrink:0; position:relative; z-index:1; }
  .bar-grand  { background:linear-gradient(90deg,#FFD700,#F97316,#FFD700); background-size:200% 100%; animation:bar-shift 6s ease-in-out infinite; }
  .bar-1st   { background:linear-gradient(90deg,var(--primary),#FB923C); }
  .bar-2nd   { background:linear-gradient(90deg,var(--cyan),#60A5FA); }
  .bar-award { background:linear-gradient(90deg,var(--purple),#C084FC); }
  @keyframes bar-shift { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }

  .pcard-thumb { position:relative; width:100%; aspect-ratio:16/9; overflow:hidden; background:#0a0913; flex-shrink:0; cursor:pointer; }
  .pcard-grand .pcard-thumb { width:58%; aspect-ratio:auto; align-self:stretch; min-height:380px; }
  .pcard-thumb img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease, filter .3s ease; filter:brightness(.92) saturate(1); }
  .pcard:hover .pcard-thumb img { transform:scale(1.05); filter:brightness(1) saturate(1.05); }
  .pcard-thumb-empty { background:radial-gradient(circle at 50% 40%, rgba(249,115,22,.06) 0%, transparent 60%), linear-gradient(135deg,#0d0c18,#1a1828); }
  .pcard-thumb-empty .pcard-rec { display:none; }

  /* HUD corner brackets on the thumbnail */
  .pcard-thumb::before, .pcard-thumb::after { content:''; position:absolute; width:18px; height:18px; pointer-events:none; transition:border-color .3s, opacity .3s; opacity:.55; z-index:2; }
  .pcard-thumb::before { top:10px; left:10px; border-top:1.5px solid rgba(255,255,255,.7); border-left:1.5px solid rgba(255,255,255,.7); }
  .pcard-thumb::after { bottom:10px; right:10px; border-bottom:1.5px solid rgba(255,255,255,.7); border-right:1.5px solid rgba(255,255,255,.7); }
  .pcard:hover .pcard-thumb::before, .pcard:hover .pcard-thumb::after { border-color:var(--primary); opacity:1; }
  .pcard-grand:hover .pcard-thumb::before, .pcard-grand:hover .pcard-thumb::after { border-color:#FFD700; }

  /* REC / DEMO indicator */
  .pcard-thumb .pcard-rec { position:absolute; top:14px; right:14px; display:inline-flex; align-items:center; gap:.4rem; font-family:var(--mono); font-size:.55rem; letter-spacing:.2em; color:rgba(255,255,255,.85); background:rgba(0,0,0,.55); backdrop-filter:blur(6px); padding:.3rem .55rem; border-radius:3px; border:1px solid rgba(255,255,255,.1); z-index:3; }
  .pcard-thumb .pcard-rec::before { content:''; width:6px; height:6px; border-radius:50%; background:#ef4444; box-shadow:0 0 6px #ef4444; animation:rec-blink 1.4s ease-in-out infinite; }
  @keyframes rec-blink { 0%,100%{opacity:1} 50%{opacity:.35} }

  .pcard-play-overlay { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:.85rem; background:linear-gradient(180deg, rgba(6,5,13,.15) 0%, rgba(6,5,13,.55) 100%); transition:background .3s; z-index:2; }
  .pcard:hover .pcard-play-overlay { background:linear-gradient(180deg, rgba(6,5,13,.25) 0%, rgba(6,5,13,.7) 100%); }

  .play-btn { width:60px; height:60px; border-radius:50%; background:rgba(249,115,22,.92); display:flex; align-items:center; justify-content:center; color:#000; box-shadow:0 0 0 0 rgba(249,115,22,.6), 0 8px 24px rgba(0,0,0,.4); transition:transform .25s ease, box-shadow .25s ease; animation:play-pulse 2.4s ease-in-out infinite; padding-left:4px; position:relative; z-index:1; }
  .pcard-grand .play-btn { width:78px; height:78px; background:rgba(255,215,0,.95); }
  .pcard:hover .play-btn { transform:scale(1.12); box-shadow:0 0 0 8px rgba(249,115,22,.18), 0 12px 30px rgba(0,0,0,.5); animation:none; }
  .pcard-grand:hover .play-btn { box-shadow:0 0 0 10px rgba(255,215,0,.18), 0 14px 36px rgba(0,0,0,.55); }
  @keyframes play-pulse { 0%,100% { box-shadow:0 0 0 0 rgba(249,115,22,.5), 0 8px 24px rgba(0,0,0,.4); } 50% { box-shadow:0 0 0 14px rgba(249,115,22,0), 0 8px 24px rgba(0,0,0,.4); } }

  .play-label { font-family:var(--mono); font-size:.6rem; letter-spacing:.28em; color:rgba(255,255,255,.85); opacity:0; transform:translateY(6px); transition:opacity .25s, transform .25s; text-shadow:0 1px 4px rgba(0,0,0,.6); }
  .pcard:hover .play-label { opacity:1; transform:translateY(0); }

  .pcard-body { padding:1.6rem 1.5rem 1.25rem; display:flex; flex-direction:column; gap:.55rem; flex:1; }
  .pcard-badges { display:flex; flex-wrap:wrap; gap:.45rem; align-items:center; }
  .pbadge { font-family:var(--mono); font-size:.62rem; font-weight:700; letter-spacing:.2em; padding:.4rem .8rem; border-radius:4px; border:1px solid; white-space:nowrap; display:inline-flex; align-items:center; gap:.35rem; }
  .pbadge-1st   { color:#fff; border-color:var(--primary); background:linear-gradient(135deg, rgba(249,115,22,.4) 0%, rgba(249,115,22,.18) 100%); box-shadow:0 0 14px rgba(249,115,22,.28), inset 0 1px 0 rgba(255,255,255,.1); }
  .pbadge-1st::before { content:'★'; font-size:.7rem; color:#FFD27A; }
  .pbadge-2nd   { color:#fff; border-color:var(--cyan); background:linear-gradient(135deg, rgba(0,212,255,.32) 0%, rgba(0,212,255,.14) 100%); box-shadow:0 0 14px rgba(0,212,255,.22), inset 0 1px 0 rgba(255,255,255,.1); }
  .pbadge-award { color:#fff; border-color:var(--purple); background:linear-gradient(135deg, rgba(168,85,247,.36) 0%, rgba(168,85,247,.16) 100%); box-shadow:0 0 14px rgba(168,85,247,.22), inset 0 1px 0 rgba(255,255,255,.1); }
  .pbadge-extra { color:rgba(255,255,255,.72); border-color:rgba(255,255,255,.18); background:transparent; font-weight:600; }

  /* Team avatars */
  .pcard-team { display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; font-family:var(--mono); }
  .team-label { font-size:.55rem; letter-spacing:.28em; color:rgba(255,255,255,.45); font-weight:500; text-transform:uppercase; }
  .team-avatar { width:30px; height:30px; border-radius:50%; background:rgba(249,115,22,.14); border:1px solid rgba(249,115,22,.32); display:inline-flex; align-items:center; justify-content:center; font-family:var(--display); font-size:.62rem; font-weight:700; color:#fff; letter-spacing:.02em; cursor:default; position:relative; transition:background .2s, transform .2s, border-color .2s, box-shadow .2s; }
  .team-avatar:hover { background:rgba(249,115,22,.32); border-color:var(--primary); transform:translateY(-2px); box-shadow:0 4px 14px rgba(249,115,22,.3); z-index:10; }
  .team-avatar::after { content:attr(data-name); position:absolute; bottom:calc(100% + 10px); left:50%; transform:translateX(-50%) translateY(4px); background:rgba(8,6,16,.96); color:#fff; padding:.45rem .7rem; border-radius:5px; font-family:var(--mono); font-size:.58rem; letter-spacing:.1em; white-space:nowrap; pointer-events:none; border:1px solid rgba(249,115,22,.3); text-transform:uppercase; opacity:0; transition:opacity .18s, transform .18s; box-shadow:0 6px 20px rgba(0,0,0,.5); }
  .team-avatar::before { content:''; position:absolute; bottom:100%; left:50%; width:0; height:0; border:5px solid transparent; border-top-color:rgba(8,6,16,.96); margin-bottom:1px; transform:translateX(-50%); opacity:0; transition:opacity .18s; pointer-events:none; }
  .team-avatar:hover::after { opacity:1; transform:translateX(-50%) translateY(0); }
  .team-avatar:hover::before { opacity:1; }

  .pcard-title { font-family:var(--display); font-weight:700; font-size:1.3rem; letter-spacing:-.005em; color:#fff; line-height:1.2; margin-top:.15rem; }
  .pcard-grand .pcard-title { font-family:var(--serif); font-size:2.4rem; font-weight:800; letter-spacing:-.02em; line-height:1.05; }
  .pcard-team { font-family:var(--mono); font-size:.62rem; letter-spacing:.08em; color:var(--muted); text-transform:uppercase; }
  .pcard-grand .pcard-team { font-size:.7rem; letter-spacing:.12em; color:rgba(255,215,0,.7); }
  .pcard-desc { font-size:.88rem; color:var(--light); line-height:1.7; flex:1; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical; overflow:hidden; }
  .pcard-grand .pcard-desc { font-size:1rem; -webkit-line-clamp:7; color:rgba(242,234,214,.78); }

  .pcard-actions { display:flex; gap:.65rem; padding:1.1rem 1.5rem 1.4rem; flex-wrap:wrap; align-items:center; border-top:1px solid rgba(255,255,255,.06); background:#100e1a; }
  .pcard-demo { display:inline-flex; align-items:center; gap:.5rem; font-family:var(--display); font-weight:700; font-size:.78rem; letter-spacing:.12em; color:#000; background:var(--primary); border:none; cursor:pointer; padding:.62rem 1.2rem; border-radius:6px; transition:background .2s, box-shadow .2s, transform .15s; white-space:nowrap; }
  .pcard-demo:hover { background:var(--pl); box-shadow:0 0 22px rgba(249,115,22,.5); transform:translateY(-1px); }
  .pcard-grand .pcard-demo { background:#FFD700; padding:.78rem 1.5rem; font-size:.85rem; }
  .pcard-grand .pcard-demo:hover { background:#FFE45C; box-shadow:0 0 28px rgba(255,215,0,.5); }
  .pcard-devpost { display:inline-flex; align-items:center; gap:.4rem; font-family:var(--mono); font-weight:600; font-size:.68rem; letter-spacing:.16em; color:var(--primary); border:1px solid rgba(249,115,22,.45); background:rgba(249,115,22,.08); padding:.62rem 1.1rem; border-radius:6px; transition:color .2s, border-color .2s, background .2s, box-shadow .2s, transform .15s; white-space:nowrap; }
  .pcard-devpost:hover { color:#fff; border-color:var(--primary); background:rgba(249,115,22,.18); box-shadow:0 0 18px rgba(249,115,22,.3); transform:translateY(-1px); }
  .pcard-grand .pcard-devpost { padding:.85rem 1.4rem; font-size:.74rem; color:#FFD700; border-color:rgba(255,215,0,.5); background:rgba(255,215,0,.08); }
  .pcard-grand .pcard-devpost:hover { color:#000; background:#FFD700; border-color:#FFD700; box-shadow:0 0 24px rgba(255,215,0,.45); }

  /* ── GALLERY TEASER ── */
  .gallery-teaser { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 14px; overflow: hidden; border: 1px solid rgba(249,115,22,.15); min-height: 420px; }
  .gallery-teaser-photos { position: relative; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4px; background: var(--card-b); }
  .gt-photo { overflow: hidden; position: relative; }
  .gt-photo img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s ease; }
  .gallery-teaser:hover .gt-photo img { transform: scale(1.04); }
  .gt-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(6,5,13,.1) 0%, rgba(6,5,13,.5) 100%); pointer-events: none; }
  .gallery-teaser-content { background: linear-gradient(135deg, rgba(249,115,22,.06) 0%, transparent 60%); padding: 3.5rem; display: flex; flex-direction: column; justify-content: center; border-left: 1px solid rgba(249,115,22,.12); }

  @media (max-width: 768px) {
    .gallery-teaser { grid-template-columns: 1fr; }
