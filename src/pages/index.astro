  .hero-grid-bg { position:absolute; inset:0; background-image:radial-gradient(circle, rgba(249,115,22,.08) 1px, transparent 1px); background-size:40px 40px; mask-image:radial-gradient(ellipse 85% 75% at 50% 40%, black 0%, transparent 100%); }
  #bg-canvas { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; }

  .hud-tl,.hud-tr,.hud-bl,.hud-br { position:absolute; font-family:var(--mono); font-size:.61rem; letter-spacing:.12em; color:rgba(255,255,255,.55); z-index:2; pointer-events:none; display:flex; align-items:center; gap:.5rem; }
  .hud-tl { top:2.5rem; left:1.25rem; }
  .hud-tr { top:2.5rem; right:1.25rem; }
  .hud-bl { bottom:1.25rem; left:1.25rem; }
  .hud-br { bottom:1.25rem; right:1.25rem; }
  .hud-label-accent { color: var(--primary); }
  .hud-label-white { color: rgba(255,255,255,.75); }
  .hud-sep { color:rgba(255,255,255,.1); }
  .hud-live { color: var(--green); }
  .hud-count { color:var(--cyan); font-weight:600; }

  .float-el { position:absolute; pointer-events:none; z-index:1; }
  .fe-hex-1 { top:18%; left:7%; animation:floaty 7s ease-in-out infinite; }
  .fe-hex-2 { top:55%; right:8%; animation:floaty 9s ease-in-out infinite reverse; }
  .fe-hex-3 { top:28%; right:5%; animation:floaty 11s ease-in-out infinite; opacity:.7; }
  .fe-plus-1 { top:22%; left:22%; font-size:1.3rem; color:rgba(249,115,22,.35); font-weight:300; animation:floaty 6s ease-in-out infinite; }
  .fe-plus-2 { bottom:32%; right:22%; font-size:.9rem; color:rgba(0,212,255,.3); animation:floaty 8s ease-in-out infinite reverse; }
  .fe-plus-3 { top:45%; left:14%; font-size:.75rem; color:rgba(249,115,22,.2); animation:floaty 10s ease-in-out infinite; }
  .fe-ring-1 { width:90px; height:90px; border:1px solid rgba(249,115,22,.12); border-radius:50%; bottom:28%; left:10%; animation:floaty 10s ease-in-out infinite; }
  .fe-ring-2 { width:55px; height:55px; border:1px solid rgba(0,212,255,.1); border-radius:50%; top:35%; right:16%; animation:floaty 12s ease-in-out infinite reverse; }
  .fe-ring-3 { width:130px; height:130px; border:1px solid rgba(249,115,22,.06); border-radius:50%; top:60%; left:18%; animation:floaty 15s ease-in-out infinite; }
  @keyframes floaty { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-16px)} }

  .hero-spotlight { position: absolute; width: 1200px; height: 1200px; background: radial-gradient(circle, rgba(249,115,22,.075) 0%, rgba(249,115,22,.02) 40%, transparent 70%); top: 40%; left: 50%; transform: translate(-50%, -55%); pointer-events: none; z-index: 1; animation: spotlight-pulse 6s ease-in-out infinite; }
  @keyframes spotlight-pulse { 0%,100% { opacity:.8; transform:translate(-50%,-55%) scale(1); } 50% { opacity:1; transform:translate(-50%,-55%) scale(1.1); } }

  .hero-content { position:relative; z-index:2; max-width:860px; width:100%; display:flex; flex-direction:column; align-items:center; gap:0; }

  .hero-series-badge { display:inline-flex; align-items:center; gap:.5rem; font-family:var(--mono); font-size:.63rem; letter-spacing:.2em; color:rgba(242,234,214,.6); background:rgba(249,115,22,.06); border:1px solid rgba(249,115,22,.18); padding:.4rem 1.1rem; border-radius:100px; margin-bottom:2rem; }
  .series-dot { width:6px; height:6px; border-radius:50%; background:var(--green); box-shadow:0 0 8px var(--green); animation:blink 2s ease-in-out infinite; flex-shrink:0; }
  .series-sep { color:rgba(255,255,255,.2); }
  .series-event { color:var(--primary); font-weight:600; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.25} }

  .hero-title { display:flex; flex-direction:column; align-items:center; gap:.5rem; margin-bottom:1.5rem; }
  .hero-j-logo { width: clamp(3rem, 7vw, 5.5rem); height: auto; object-fit: contain; filter: drop-shadow(0 0 22px rgba(249,115,22,.6)) drop-shadow(0 0 60px rgba(249,115,22,.2)); }
  .title-main { font-family: var(--serif); font-weight: 800; font-size: clamp(2.2rem, 6.5vw, 5.5rem); color: #F3EBD7; letter-spacing: -.03em; line-height: 1; text-align:center; }
  .title-spring { font-style: italic; color: var(--primary); }

  .hero-sub { font-family: var(--display); font-weight: 500; font-size: clamp(.95rem, 2.2vw, 1.2rem); color: rgba(242,234,214,.65); margin-bottom: 1.25rem; line-height: 1.5; max-width:540px; text-align:center; }

  .hero-meta-line { display:flex; align-items:center; gap:.9rem; font-family:var(--mono); font-size:.88rem; letter-spacing:.18em; color:var(--cyan); margin-bottom:2.5rem; flex-wrap:wrap; justify-content:center; text-shadow: 0 0 18px rgba(0,212,255,.35); }
  .meta-dot { color:rgba(249,115,22,.5); }

  /* ── COUNTDOWN ── */
  .countdown { display:flex; align-items:center; gap:.75rem; margin-bottom:2rem; }
  .cd-block { display:flex; flex-direction:column; align-items:center; gap:.2rem; background:rgba(249,115,22,.07); border:1px solid rgba(249,115,22,.35); border-radius:8px; padding:.5rem .9rem; min-width:56px; box-shadow:0 0 14px rgba(249,115,22,.1), inset 0 1px 0 rgba(255,255,255,.06); }
  .cd-val { font-family:var(--display); font-size:1.55rem; font-weight:700; color:#fff; line-height:1; letter-spacing:.02em; text-shadow:0 0 16px rgba(249,115,22,.45); }
  .cd-label { font-family:var(--mono); font-size:.52rem; letter-spacing:.22em; color:rgba(255,255,255,.7); font-weight:500; }
  .cd-sep { font-family:var(--display); font-size:1.1rem; font-weight:700; color:rgba(249,115,22,.6); margin-bottom:.7rem; text-shadow:0 0 10px rgba(249,115,22,.35); }

  .cta-group { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
  .btn-primary { display:inline-flex; align-items:center; gap:.6rem; font-family:var(--display); font-weight:700; font-size:1.05rem; letter-spacing:.1em; color:#000; background:var(--primary); padding:.9rem 2.5rem; clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%); transition:all .2s; box-shadow:0 0 40px rgba(249,115,22,.4),0 0 80px rgba(249,115,22,.1); }
  .btn-primary:hover { background:var(--pl); box-shadow:0 0 65px rgba(249,115,22,.7),0 0 130px rgba(249,115,22,.2); transform:translateY(-2px); color:#000; }
  .btn-ghost { display:inline-flex; align-items:center; gap:.5rem; font-family:var(--display); font-weight:600; font-size:1.05rem; letter-spacing:.1em; color:var(--light); border:1px solid var(--border); padding:.9rem 2rem; clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%); transition:all .2s; }
  .btn-ghost:hover { border-color:var(--primary); color:var(--primary); box-shadow:0 0 25px rgba(249,115,22,.12); }
  .btn-coming-soon { display:inline-flex; align-items:center; gap:.65rem; font-family:var(--display); font-weight:700; font-size:1.05rem; letter-spacing:.1em; color:var(--green); border:1px solid rgba(34,197,94,.3); background:rgba(34,197,94,.06); padding:.9rem 2.2rem; clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%); cursor:default; }
  .cs-dot { width:8px; height:8px; border-radius:50%; background:var(--green); box-shadow:0 0 10px var(--green); animation:blink 1.8s ease-in-out infinite; flex-shrink:0; }

  .scroll-down { position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:.4rem; color:var(--muted); font-family:var(--mono); font-size:.58rem; letter-spacing:.22em; animation:bob 2s ease-in-out infinite; }
  @keyframes bob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

  /* ── SPRING SECTION ── */
  .section-spring { background: linear-gradient(180deg, rgba(249,115,22,.04) 0%, transparent 60%); }
  .spring-header { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; margin-bottom:4rem; }
  .spring-header-left { display:flex; flex-direction:column; }
  .spring-header-right { color:var(--light); font-size:1.05rem; line-height:1.75; }
  @media(max-width:768px) {
    .spring-header { grid-template-columns:1fr; gap:1.25rem; }
  }

  .spring-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; margin-bottom:3.5rem; }
  .spring-card { background:var(--card); border:1px solid var(--card-b); border-radius:12px; padding:2rem 1.75rem; display:flex; flex-direction:column; gap:1.1rem; transition:transform .25s, border-color .25s, box-shadow .25s; position:relative; overflow:hidden; }
  .spring-card::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg, rgba(249,115,22,.04) 0%, transparent 60%); pointer-events:none; }
  .spring-card:hover { transform:translateY(-5px); border-color:rgba(249,115,22,.25); box-shadow:0 12px 40px rgba(0,0,0,.4), 0 0 30px rgba(249,115,22,.07); }
  .spring-card-icon { width:52px; height:52px; border-radius:10px; background:rgba(249,115,22,.08); border:1px solid rgba(249,115,22,.15); display:flex; align-items:center; justify-content:center; color:var(--primary); flex-shrink:0; }
  .spring-card-title { font-family:var(--display); font-weight:700; font-size:1.15rem; letter-spacing:.04em; color:#fff; }
  .spring-card-desc { font-size:.875rem; color:var(--light); line-height:1.68; }

  .spring-notify { background: linear-gradient(135deg, rgba(249,115,22,.07) 0%, rgba(168,85,247,.04) 100%); border: 1px solid rgba(249,115,22,.2); border-radius:14px; overflow:hidden; position:relative; }
  .spring-notify::before { content:''; position:absolute; inset:0; background: repeating-linear-gradient(90deg, rgba(249,115,22,.03) 0px, rgba(249,115,22,.03) 1px, transparent 1px, transparent 60px); pointer-events:none; }
  .notify-inner { position:relative; padding:3.5rem 3rem; display:flex; flex-direction:column; align-items:center; gap:1.25rem; text-align:center; }
  .notify-badge { display:inline-flex; align-items:center; gap:.6rem; font-family:var(--mono); font-size:.65rem; letter-spacing:.2em; color:var(--green); background:rgba(34,197,94,.08); border:1px solid rgba(34,197,94,.25); padding:.45rem 1.2rem; border-radius:100px; }
  .notify-dot { width:6px; height:6px; border-radius:50%; background:var(--green); box-shadow:0 0 8px var(--green); animation:blink 1.8s ease-in-out infinite; }
  .notify-text { font-family:var(--display); font-weight:600; font-size:1.25rem; color:var(--light); letter-spacing:.03em; }
  .notify-actions { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-top:.5rem; }

  /* ── GRAND PRIZE GLOW ── */
  .wc-grand-glow { position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 80% 60% at 50% 0%, rgba(249,115,22,.12) 0%, transparent 70%); z-index:0; }

  /* ── PLATINUM SPONSOR ── */
  .platinum-sponsor { display: flex; flex-direction: column; align-items: center; gap: 1.25rem; padding: 5rem 2rem; background: radial-gradient(circle at center, rgba(249,115,22,.07) 0%, transparent 70%); position: relative; z-index: 1; }
  .platinum-label { font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.4em; color: var(--primary); opacity: 0.75; }
  .platinum-logo { height: 90px; width: auto; filter: drop-shadow(0 0 28px rgba(249,115,22,.35)); transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease; }
  .platinum-link:hover .platinum-logo { transform: scale(1.08); filter: drop-shadow(0 0 45px rgba(249,115,22,.55)); }
  .platinum-desc { font-family: var(--display); font-weight: 500; font-size: 1.15rem; color: var(--light); letter-spacing: 0.05em; opacity: 0.8; max-width: 400px; text-align: center; line-height: 1.4; }

  /* ── SPONSOR STRIP ── */
  .sponsor-strip { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 2rem 0; background: rgba(0,0,0,.2); border-top: 1px solid rgba(255,255,255,.05); border-bottom: 1px solid rgba(255,255,255,.05); position: relative; z-index: 1; overflow: hidden; }
  .strip-label { font-family: var(--mono); font-size: .6rem; letter-spacing: .3em; color: rgba(255,255,255,.65); white-space: nowrap; }
  .strip-marquee { width: 100%; overflow: hidden; }
  .strip-track { display: flex; align-items: center; width: max-content; animation: scroll 60s linear infinite; }
  .strip-track:hover { animation-play-state: paused; }
  .strip-logo { display: flex; align-items: center; justify-content: center; padding: 0 2.5rem; flex-shrink: 0; transition: opacity .2s; }
  .strip-logo:hover { opacity: .7; }
  .strip-logo img { height: 58px; max-width: 180px; width: auto; object-fit: contain; filter: brightness(.85) grayscale(.2); transition: filter .2s; }
  .strip-logo img.velric-lg { height: 58px; max-width: 180px; }
  .strip-logo:hover img { filter: brightness(1.1) grayscale(0); }
  @keyframes scroll { from{transform:translateX(0)} to{transform:translateX(-33.333%)} }

  /* ── V1 BANNER ── */
  .v1-banner { position:relative; z-index:1; min-height:420px; display:flex; align-items:center; justify-content:center; overflow:hidden; }
  .v1-banner-bg { position:absolute; inset:0; }
  .v1-banner-bg img { width:100%; height:100%; object-fit:cover; object-position:center 30%; display:block; }
  .v1-banner-overlay { position:absolute; inset:0; background: linear-gradient(to bottom, rgba(6,5,13,.55) 0%, rgba(6,5,13,.3) 40%, rgba(6,5,13,.8) 85%, rgba(6,5,13,1) 100%), linear-gradient(to right, rgba(6,5,13,.6) 0%, transparent 40%, transparent 60%, rgba(6,5,13,.6) 100%); }
  .v1-banner-content { position:relative; z-index:2; text-align:center; padding:5rem 2rem; display:flex; flex-direction:column; align-items:center; gap:1rem; }
  .v1-banner-eyebrow { font-family:var(--mono); font-size:.65rem; letter-spacing:.3em; color:rgba(249,115,22,.8); }
  .v1-banner-title { font-family:var(--serif); font-weight:800; font-size:clamp(3rem,8vw,6.5rem); color:#F3EBD7; letter-spacing:-.025em; line-height:1; }
  .v1-banner-accent { color:var(--primary); font-style:italic; }
  .v1-banner-sub { font-family:var(--display); font-weight:500; font-size:1.1rem; color:rgba(242,234,214,.65); letter-spacing:.04em; }
  .v1-stats-row { display:flex; align-items:center; gap:.5rem; margin-top:1.5rem; background:rgba(6,5,13,.5); border:1px solid rgba(249,115,22,.2); border-radius:10px; padding:.9rem 2rem; backdrop-filter:blur(12px); flex-wrap:wrap; justify-content:center; }
  .v1-stat { display:flex; flex-direction:column; align-items:center; padding:.2rem 1.5rem; gap:.15rem; }
  .v1-stat-val { font-family:var(--display); font-weight:700; font-size:1.9rem; letter-spacing:-.02em; color:var(--primary); line-height:1; }
  .v1-stat-key { font-family:var(--mono); font-size:.55rem; letter-spacing:.2em; color:var(--muted); }
  .v1-stat-sep { font-family:var(--mono); color:rgba(249,115,22,.25); font-size:.85rem; padding:0 .25rem; }

  /* ── SECTIONS ── */
  .section { padding:7rem 2rem; position:relative; z-index:1; }
  .section::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(249,115,22,.18) 30%,rgba(249,115,22,.18) 70%,transparent); }
  .section-dark { background:linear-gradient(180deg,rgba(0,0,0,.25) 0%,transparent 100%); }
  .container { max-width:1200px; margin:0 auto; }
  .section-eyebrow { font-family:var(--mono); font-size:.68rem; font-weight:500; letter-spacing:.25em; color:var(--primary); margin-bottom:.75rem; }
  .section-title { font-family:var(--display); font-weight:700; font-size:clamp(2rem,5vw,3.5rem); letter-spacing:-.01em; color:#fff; margin-bottom:1rem; }
  .section-sub { color:var(--light); font-size:.97rem; line-height:1.68; max-width:600px; }
  .section-header { margin-bottom:4rem; }

  .reveal { opacity:0; transform:translateY(28px); transition:opacity .7s ease,transform .7s ease; will-change: transform, opacity; }
  .reveal.revealed { opacity:1; transform:translateY(0); }
  .delay-1 { transition-delay:.12s; }
  .delay-2 { transition-delay:.24s; }
  .delay-3 { transition-delay:.36s; }

  .corner { position:absolute; width:14px; height:14px; }
  .corner.tl { top:0; left:0; border-top:2px solid; border-left:2px solid; }
  .corner.tr { top:0; right:0; border-top:2px solid; border-right:2px solid; }
  .corner.bl { bottom:0; left:0; border-bottom:2px solid; border-left:2px solid; }
  .corner.br { bottom:0; right:0; border-bottom:2px solid; border-right:2px solid; }
  .kc-corners,.wc-corners { position:absolute; inset:0; pointer-events:none; z-index:2; }

  /* ── WINNERS ── */
  .winner-grand { margin-bottom:1.5rem; }

  .winner-card { display:block; background:var(--card); border:1px solid var(--card-b); border-radius:12px; overflow:hidden; position:relative; transition:transform .22s, border-color .22s, box-shadow .22s; color: inherit; }
  .winner-card:hover { transform:translateY(-5px); }

  .wc-grand { border-color: rgba(249,115,22,.25); box-shadow: 0 0 40px rgba(249,115,22,.08); }
  .wc-grand .wc-corners .corner { border-color: var(--primary); }
  .wc-grand:hover { border-color:rgba(249,115,22,.5); box-shadow:0 0 80px rgba(249,115,22,.2), 0 20px 60px rgba(0,0,0,.5); }
  .wc-grand .wc-inner { display:grid; grid-template-columns:1.3fr 1fr; }

  .wc-1st .wc-corners .corner { border-color: var(--primary); }
  .wc-1st:hover { border-color:rgba(249,115,22,.3); box-shadow:0 0 35px rgba(249,115,22,.1); }
  .wc-2nd .wc-corners .corner { border-color: var(--cyan); }
  .wc-2nd:hover { border-color:rgba(0,212,255,.3); box-shadow:0 0 35px rgba(0,212,255,.08); }
  .wc-award .wc-corners .corner { border-color: var(--purple); }
  .wc-award:hover { border-color:rgba(168,85,247,.3); box-shadow:0 0 35px rgba(168,85,247,.08); }

  .winner-img { background:var(--card-b); min-height:300px; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
  .winner-img img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:1; display:block; }
  .winner-img-empty::after { content:'NO IMAGE'; font-family:var(--mono); font-size:.62rem; letter-spacing:.2em; color:rgba(255,255,255,.1); }
  .winner-img:not(.winner-img-empty)::after { display:none; }
  .winner-img-sm { min-height:200px; }

  .winner-content { padding:2rem; display:flex; flex-direction:column; }
  .wc-grand .winner-content { justify-content:center; padding:2.5rem; }

  .winner-badges { display:flex; align-items:center; flex-wrap:wrap; gap:.5rem; margin-bottom:.75rem; }
  .winner-place { font-family:var(--mono); font-size:.6rem; font-weight:600; letter-spacing:.2em; padding:.2rem .6rem; border-radius:3px; border:1px solid; }
  .wc-place-grand { color:var(--primary); border-color:rgba(249,115,22,.3); background:rgba(249,115,22,.08); }
  .wc-place-1st  { color:var(--primary); border-color:rgba(249,115,22,.3); background:rgba(249,115,22,.08); }
  .wc-place-2nd  { color:var(--cyan);    border-color:rgba(0,212,255,.3);   background:rgba(0,212,255,.06); }
  .wc-place-award { color:var(--purple); border-color:rgba(168,85,247,.3);  background:rgba(168,85,247,.07); }
  .winner-award-tag { font-family:var(--mono); font-size:.58rem; letter-spacing:.12em; color:var(--muted); border:1px solid var(--border); padding:.2rem .5rem; border-radius:3px; }

  .winner-name { font-family:var(--display); font-weight:700; font-size:1.45rem; letter-spacing:-.01em; color:#fff; margin-bottom:.35rem; line-height:1.15; }
  .wc-grand .winner-name { font-size:1.95rem; }
  .winner-team { font-family:var(--mono); font-size:.62rem; letter-spacing:.06em; color:var(--muted); margin-bottom:.85rem; }
  .winner-desc { font-size:.875rem; color:var(--light); line-height:1.7; flex:1; }
  .winner-link { font-family:var(--mono); font-size:.62rem; letter-spacing:.1em; color:var(--primary); margin-top:1.25rem; display:inline-block; opacity:.75; transition:opacity .2s; }
  .winner-card:hover .winner-link { opacity:1; }

  .track-section { margin-bottom:4.5rem; }
  .track-header { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2rem; padding: 1.25rem 1.75rem; background: linear-gradient(90deg, rgba(249,115,22,.07) 0%, transparent 100%); border: 1px solid rgba(249,115,22,.16); border-left: 3px solid var(--primary); border-radius: 0 8px 8px 0; position: relative; overflow: hidden; }
  .track-header::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(90deg, rgba(249,115,22,.035) 0px, rgba(249,115,22,.035) 1px, transparent 1px, transparent 40px); pointer-events: none; }
  .track-header-icon { font-family: var(--mono); font-size: 1.1rem; color: var(--primary); opacity: .7; flex-shrink: 0; line-height: 1; }
  .track-label { font-family: var(--display); font-size: 1.15rem; font-weight: 700; letter-spacing: .08em; color: #fff; text-transform: uppercase; }
  .track-label-sub { font-family: var(--mono); font-size: .6rem; letter-spacing: .2em; color: var(--muted); margin-left: auto; flex-shrink: 0; }
  .track-row { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  .awards-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }

  /* ── GALLERY TEASER ── */
  .gallery-teaser { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 14px; overflow: hidden; border: 1px solid rgba(249,115,22,.15); min-height: 420px; }
