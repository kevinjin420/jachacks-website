    <!-- JACHACKS 1.0 BANNER -->
    <div class="v1-banner">
      <div class="v1-banner-bg">
        <img src="/photos/DSC06792.webp" alt="JacHacks 1.0" />
        <div class="v1-banner-overlay"></div>
      </div>
      <div class="v1-banner-content">
        <div class="v1-banner-eyebrow">// APR 4–5, 2026 · ANN ARBOR, MI</div>
        <div class="v1-banner-title">JacHacks <span class="v1-banner-accent">1.0</span></div>
        <div class="v1-banner-sub">Where it all started — 170+ builders, 70 projects, 24 hours.</div>
        <div class="v1-stats-row">
          <div class="v1-stat">
            <span class="v1-stat-val">170+</span>
            <span class="v1-stat-key">ATTENDEES</span>
          </div>
          <div class="v1-stat-sep">//</div>
          <div class="v1-stat">
            <span class="v1-stat-val">70</span>
            <span class="v1-stat-key">PROJECTS</span>
          </div>
          <div class="v1-stat-sep">//</div>
          <div class="v1-stat">
            <span class="v1-stat-val">24</span>
            <span class="v1-stat-key">HOURS</span>
          </div>
          <div class="v1-stat-sep">//</div>
          <div class="v1-stat">
            <span class="v1-stat-val">$5K</span>
            <span class="v1-stat-key">IN PRIZES</span>
          </div>
        </div>
      </div>
    </div>

    <!-- WINNERS -->
    <section class="section section-dark" id="winners">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-eyebrow">// JACHACKS 1.0 · WINNERS</div>
          <h2 class="section-title">The Best of <span class="text-accent">JacHacks 1.0</span></h2>
          <p class="section-sub">The projects that stood out — built in 24 hours at U-M North Campus, April 2026.</p>
        </div>

        <!-- Grand Prize -->
        <div class="winner-grand reveal">
          <a class="winner-card wc-grand" href="https://devpost.com/software/npm-supply-chain-risk-analyzer" target="_blank" rel="noopener noreferrer">
            <div class="wc-grand-glow"></div>
            <div class="wc-corners">
              <span class="corner tl"></span><span class="corner tr"></span>
              <span class="corner bl"></span><span class="corner br"></span>
            </div>
            <div class="wc-inner">
              <div class="winner-img">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/534/605/datas/gallery.jpg" alt="ChainViz" />
              </div>
              <div class="winner-content">
                <div class="winner-badges">
                  <span class="winner-place wc-place-grand">BEST USE OF JAC</span>
                </div>
                <div class="winner-name">ChainViz</div>
                <div class="winner-team">by Darsh Poddar</div>
                <p class="winner-desc">3D visualization of npm's single points of failure — with autonomous Jac agents that investigate any package's blast radius in real time. Combines historical attack replays, vulnerability scanning across 217K+ records, and multi-agent AI investigation.</p>
                <span class="winner-link">View on Devpost →</span>
              </div>
            </div>
          </a>
        </div>

        <!-- Track: Agentic AI -->
        <div class="track-section">
          <div class="track-header">
            <span class="track-header-icon">//</span>
            <span class="track-label">Agentic AI Track</span>
            <span class="track-label-sub">2 WINNERS</span>
          </div>
          <div class="track-row">
            <a class="winner-card wc-1st reveal" href="https://devpost.com/software/project-e54qlw07j9i1" target="_blank" rel="noopener noreferrer">
              <div class="wc-corners">
                <span class="corner tl"></span><span class="corner tr"></span>
                <span class="corner bl"></span><span class="corner br"></span>
              </div>
              <div class="winner-img winner-img-sm">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/534/388/datas/original.png" alt="GraphClaw" />
              </div>
              <div class="winner-content">
                <div class="winner-badges">
                  <span class="winner-place wc-place-1st">1ST PLACE</span>
                  <span class="winner-award-tag">+ BEST USE OF BASE44</span>
                </div>
                <div class="winner-name">GraphClaw</div>
                <div class="winner-team">by A K M Mahmudul Kabir, Abdullah Al Mahmud</div>
                <p class="winner-desc">A multi-agent AI platform where memory lives in a property graph, agents are graph walkers, and skills can be installed from the internet at runtime.</p>
                <span class="winner-link">View on Devpost →</span>
              </div>
            </a>

            <a class="winner-card wc-2nd reveal delay-1" href="https://devpost.com/software/ghostwatch" target="_blank" rel="noopener noreferrer">
              <div class="wc-corners">
                <span class="corner tl"></span><span class="corner tr"></span>
                <span class="corner bl"></span><span class="corner br"></span>
              </div>
              <div class="winner-img winner-img-sm">
                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/533/420/datas/gallery.jpg" alt="GhostWatch" />
              </div>
              <div class="winner-content">
                <div class="winner-badges">
                  <span class="winner-place wc-place-2nd">2ND PLACE</span>
                </div>
                <div class="winner-name">GhostWatch</div>
                <div class="winner-team">by Aaron Sun, Ayush Madhav Kumar</div>
                <p class="winner-desc">Autonomous code defense with graph-native clarity. Monitors repositories for risky dependency changes and PR signals, with automated sandboxed testing and optional fix generation.</p>
                <span class="winner-link">View on Devpost →</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Track: Fintech -->
        <div class="track-section">
          <div class="track-header">
            <span class="track-header-icon">//</span>
            <span class="track-label">Fintech Track</span>
            <span class="track-label-sub">2 WINNERS</span>
          </div>
          <div class="track-row">
            <a class="winner-card wc-1st reveal" href="https://devpost.com/software/polywatch" target="_blank" rel="noopener noreferrer">
              <div class="wc-corners">
                <span class="corner tl"></span><span class="corner tr"></span>
                <span class="corner bl"></span><span class="corner br"></span>
              </div>
              <div class="winner-img winner-img-sm winner-img-empty"></div>
              <div class="winner-content">
                <div class="winner-badges">
                  <span class="winner-place wc-place-1st">1ST PLACE</span>
                </div>
