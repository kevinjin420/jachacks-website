---
import '../styles/site.css';
---

<html lang="en">
  <head>
    <script is:inline>
      try { var t = localStorage.getItem('theme'); if (t === 'light') document.documentElement.setAttribute('data-theme','light'); } catch(e){}
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/jaseci-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JacHacks Spring · Winners</title>
    <meta name="description" content="JacHacks Spring 2026: winners and standout projects from the global online hackathon." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&family=Rajdhani:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>

    <!-- NAV -->
    <nav id="main-nav" class="scrolled">
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/jaseci-logo.png" alt="JacHacks" class="logo-img" />
          <span class="logo-text">Jac<span class="logo-accent">Hacks</span></span>
        </a>
        <div class="nav-links">
          <a href="/" class="nav-link">// HOME</a>
          <a href="/spring" class="nav-link">// SPRING</a>
          <a href="/winter" class="nav-link">// WINTER</a>
          <a href="/paradise" class="nav-link">// VELRIC</a>
          <a href="/ohio" class="nav-link">// ROCKETHACKS</a>
          <a href="/gallery" class="nav-link">// GALLERY</a>
        </div>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark">
          <svg class="tt-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="tt-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href="https://github.com/jaseci-labs/jaseci" target="_blank" rel="noopener noreferrer" class="nav-cta">STAR ON GITHUB</a>
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/">// HOME</a>
      <a href="/spring">// SPRING</a>
      <a href="/winter">// WINTER</a>
      <a href="/paradise">// VELRIC</a>
      <a href="/ohio">// ROCKETHACKS</a>
      <a href="/gallery">// GALLERY</a>
      <a href="https://github.com/jaseci-labs/jaseci" target="_blank" class="mobile-cta">STAR ON GITHUB</a>
    </div>

    <main class="edition-main">
