                <img src="https://d112y698adiu2z.cloudfront.net/photos/production/software_photos/004/684/289/datas/original.png" alt="Drowzie" />
                <div class="pcard-rec">DEMO</div>
                <div class="pcard-play-overlay">
                  <div class="play-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg></div>
                  <span class="play-label">CLICK TO WATCH</span>
                </div>
              </div>
              <div class="pcard-body">
                <div class="pcard-badges"><span class="pbadge pbadge-award">BEST USE OF LOVABLE</span></div>
                <h3 class="pcard-title">Drowzie</h3>
                <p class="pcard-team">Shashank Shekhar</p>
                <p class="pcard-desc">A social layer on an agentic sleep platform that logs daily habits, computes personalized correlations, and nudges users toward better sleep.</p>
              </div>
              <div class="pcard-actions">
                <a class="pcard-devpost" href="https://devpost.com/software/drowzie" target="_blank" rel="noopener noreferrer">DEVPOST →</a>
