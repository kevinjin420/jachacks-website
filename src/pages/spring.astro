      </div>
    </section>

    <!-- VIDEO MODAL -->
    <div class="vm-backdrop" id="vm-backdrop"></div>
    <div class="vm" id="vm">
      <div class="vm-shell">
        <span class="vm-caption">// PROJECT DEMO</span>
        <button class="vm-close" id="vm-close" aria-label="Close video">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <div class="vm-body">
          <iframe id="vm-iframe" src="" title="Project demo video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
