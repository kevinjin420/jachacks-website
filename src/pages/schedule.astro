---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JacHacks 2026 — Participant Guide</title>
    <meta name="description" content="JacHacks 2026 participant guide: schedule, tracks, prizes, judging, and rules." />
    <link rel="icon" type="image/png" href="/jaseci-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Rajdhani:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="schedule-page">
    <!-- Site nav (matches homepage) -->
    <nav id="main-nav">
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/jaseci-logo.png" alt="JacHacks" class="logo-img" />
          <span class="logo-text">Jac<span class="logo-accent">Hacks</span></span>
        </a>
        <div class="nav-links">
          <a href="/#about" class="nav-link">// ABOUT</a>
          <a href="/#jac" class="nav-link">// JAC STACK</a>
          <a href="/schedule" class="nav-link nav-link-active">// SCHEDULE</a>
          <a href="/#faq" class="nav-link">// FAQ</a>
        </div>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSdB0o7qlEGeT93KnQcq7V17qlQXQDcp2b2GAGHv65NtkZ75dQ/viewform" target="_blank" rel="noopener noreferrer" class="nav-cta">REGISTER NOW</a>
        <button class="hamburger" id="hamburger" type="button" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/#about">// ABOUT</a>
      <a href="/#jac">// JAC STACK</a>
      <a href="/schedule">// SCHEDULE</a>
      <a href="/#faq">// FAQ</a>
      <a href="https://docs.google.com/forms/d/e/1FAIpQLSdB0o7qlEGeT93KnQcq7V17qlQXQDcp2b2GAGHv65NtkZ75dQ/viewform" target="_blank" class="mobile-cta">REGISTER NOW</a>
    </div>

    <!-- Participant guide header -->
    <div class="header">
      <div class="header-top">
        <a href="/" class="guide-logo-link">
          <div class="logo-box"><img src="/jaseci-logo.png" alt="" class="guide-logo-img" width="44" height="44" /></div>
          <div class="logo-text">Jac<span>Hacks</span></div>
        </a>
        <div class="badge">APR_04-05_2026</div>
      </div>
      <h1>Participant<br /><span class="highlight">Guide.</span></h1>
      <p class="header-sub">Everything you need to know: tracks, prizes, schedule, and rules. Read this once, build something unforgettable.</p>
      <div class="header-pills">
        <div class="pill orange">Free to Attend</div>
        <div class="pill">$10K+ in Prizes</div>
        <div class="pill">U-M North Campus · Ann Arbor</div>
        <div class="pill">24 Hours</div>
      </div>
    </div>
    <div class="divider"></div>

    <div class="container">
      <!-- SCHEDULE -->
      <div class="section">
        <div class="section-label">// Schedule</div>
        <div class="section-title">24 Hours.</div>
        <p class="section-desc">Here's exactly how the weekend runs. Come ready, stay focused, and use every minute.</p>

        <div class="day-header">
          <div class="day-tag">DAY_01</div>
          <div class="day-title">Saturday, April 4</div>
        </div>

        <div class="schedule-list">
          <div class="schedule-item">
            <div class="s-time">8:30 – 9:30 AM</div>
            <div class="s-content">
              <div class="s-dot orange"></div>
              <div>
                <div class="s-name">Check-In</div>
                <div class="s-desc">Pick up your badge, meet your team, get settled</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">9:30 – 10:00 AM</div>
            <div class="s-content">
              <div class="s-dot"></div>
              <div>
                <div class="s-name">Team Formation</div>
                <div class="s-desc">Find your crew and lock in your project idea</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">10:00 – 11:00 AM</div>
            <div class="s-content">
              <div class="s-dot"></div>
              <div>
                <div class="s-name">Opening Ceremony</div>
                <div class="s-desc">Welcome from Jaseci, sponsor intros, track deep-dives</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">11:00 AM</div>
            <div class="s-content">
              <div class="s-dot green"></div>
              <div>
                <div class="s-name orange">Hacking Begins</div>
                <div class="s-desc">Clocks start. Build. Collaborate. Iterate.</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">12:00 – 12:30 PM</div>
            <div class="s-content">
              <div class="s-dot orange"></div>
              <div>
                <div class="s-name">JAC Intro Workshop</div>
                <div class="s-desc">Zero to JAC in 30 minutes. All levels welcome. Don't skip this.</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">12:30 – 1:00 PM</div>
            <div class="s-content">
              <div class="s-dot orange"></div>
              <div>
                <div class="s-name">Agentic AI Workshop</div>
                <div class="s-desc">Led by Jayanaka from the Jaseci Labs team. Agentic AI on JAC — the session after JAC Intro, ahead of the afternoon speaker workshops.</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">1:00 – 2:00 PM</div>
            <div class="s-content">
              <div class="s-dot"></div>
              <div>
                <div class="s-name">Lunch</div>
                <div class="s-desc">Refuel and keep the momentum going</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">2:00 – 2:30 PM</div>
            <div class="s-content">
              <div class="s-dot orange"></div>
              <div>
                <div class="s-name">Guest Speaker Workshop</div>
                <div class="s-desc">Industry speaker on building with data and AI at scale</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">3:00 – 3:30 PM</div>
            <div class="s-content">
              <div class="s-dot orange"></div>
              <div>
                <div class="s-name">How to Get Into YC</div>
                <div class="s-desc">Vatsal Shah, ex-YC founder (Fall 2025) shares what it actually takes to get in</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">6:00 – 7:00 PM</div>
            <div class="s-content">
              <div class="s-dot"></div>
              <div>
                <div class="s-name">Dinner</div>
                <div class="s-desc">Hot food to power through the night</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">11:30 PM – 12:00 AM</div>
            <div class="s-content">
              <div class="s-dot"></div>
              <div>
                <div class="s-name">Midnight Refuel</div>
                <div class="s-desc">Late night snacks. Keep building.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="day-header">
          <div class="day-tag">DAY_02</div>
          <div class="day-title">Sunday, April 5</div>
        </div>

        <div class="schedule-list">
          <div class="schedule-item">
            <div class="s-time">11:00 AM</div>
            <div class="s-content">
              <div class="s-dot red"></div>
              <div>
                <div class="s-name orange">Submissions Close</div>
                <div class="s-desc">Submit to Devpost. No late entries. No exceptions.</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">11:00 AM – 12:00 PM</div>
            <div class="s-content">
              <div class="s-dot"></div>
              <div>
                <div class="s-name">Brunch</div>
                <div class="s-desc">Fuel up for the final push</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">12:00 – 1:30 PM</div>
            <div class="s-content">
              <div class="s-dot orange"></div>
              <div>
                <div class="s-name">Project Demos</div>
                <div class="s-desc">3-minute pitches to judges and sponsors. Make it count.</div>
              </div>
            </div>
          </div>
          <div class="schedule-item">
            <div class="s-time">3:00 – 4:00 PM</div>
            <div class="s-content">
              <div class="s-dot yellow"></div>
              <div>
                <div class="s-name">Awards &amp; Closing Ceremony</div>
                <div class="s-desc">Winners. Prizes. Memories. Glory.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- TRACKS -->
      <div class="section" id="tracks">
        <div class="section-label">// Competitive Tracks</div>
        <div class="section-title">Pick Your Arena.</div>
        <p class="section-desc">Each team competes in one primary track. Teams of up to 4 people. Choose what you're best at, and go all in. All tracks require JAC as the core stack.</p>

        <div class="tracks-grid">
          <div class="track-card flagship">
            <div class="track-emoji"></div>
            <div class="track-name">Agentic AI Track</div>
            <div class="track-desc">Build a real, working agentic AI application using the JAC stack. We're not looking for demos or toy prototypes. We want agents that actually do things: reasoning, tool use, multi-step workflows, real-world impact. This is the main event.</div>
            <div class="track-prizes">
              <div class="prize-badge first">1st — $750</div>
              <div class="prize-badge second">2nd — $400</div>
            </div>
            <div class="track-ideas">
              <div class="track-ideas-label">Build something like</div>
              <div class="ideas-list">
                <div class="idea-chip">Autonomous research agents</div>
                <div class="idea-chip">Multi-agent pipelines</div>
                <div class="idea-chip">AI-powered workflow tools</div>
                <div class="idea-chip">Real-time decision systems</div>
                <div class="idea-chip">Agentic customer support</div>
              </div>
            </div>
          </div>

          <div class="track-card">
            <div class="track-emoji"></div>
            <div class="track-name">Fintech Track</div>
            <div class="track-desc">Build something in the financial technology space — payments, fraud prevention, personal finance, DeFi, or intelligent money workflows. We want real fintech built on JAC.</div>
            <div class="track-prizes">
              <div class="prize-badge first">1st — $400</div>
              <div class="prize-badge second">2nd — $250</div>
            </div>
            <div class="track-ideas">
              <div class="track-ideas-label">Build something like</div>
              <div class="ideas-list">
                <div class="idea-chip">AI-powered budgeting</div>
                <div class="idea-chip">Fraud detection tools</div>
                <div class="idea-chip">DeFi dashboards</div>
                <div class="idea-chip">Smart invoice processing</div>
              </div>
            </div>
          </div>

          <div class="track-card">
            <div class="track-name">Social Impact Track</div>
            <div class="track-desc">Build something that actually matters. Projects that tackle real-world problems in healthcare, mental health, sustainability, education, accessibility, or climate. Tech that does good.</div>
            <div class="track-prizes">
              <div class="prize-badge first">1st — $400</div>
              <div class="prize-badge second">2nd — $250</div>
            </div>
            <div class="track-ideas">
              <div class="track-ideas-label">Build something like</div>
              <div class="ideas-list">
                <div class="idea-chip">AI health diagnostics</div>
                <div class="idea-chip">Carbon footprint trackers</div>
                <div class="idea-chip">Mental health support tools</div>
                <div class="idea-chip">Accessible education platforms</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- SPECIAL AWARDS -->
      <div class="section">
        <div class="section-label">// Special Awards</div>
        <div class="section-title">Bonus Prizes.</div>
        <p class="section-desc">These awards are open to any team regardless of which track you're in. Stack multiple wins.</p>

        <div class="awards-list">
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best JAC Builder</div>
              <div class="award-desc">The team that most creatively and effectively pushes what JAC can do. Think of this as the award for the most polished JAC-native product. Deep backend integration, clean architecture, real use case.</div>
            </div>
            <div class="award-prize">$400 Cash</div>
          </div>
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best Use of Base44</div>
              <div class="award-desc">Incorporate Base44 meaningfully into your project. The team that integrates it most creatively and effectively takes this one.</div>
            </div>
            <div class="award-prize">Credits (from Base44)</div>
          </div>
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best Claude Code + JAC Dev Tool</div>
              <div class="award-desc">Use Claude Code to build tooling FOR the JAC ecosystem itself. Not an agent built with JAC, but something that makes JAC better: a VS Code extension, a linter, a debugger, a playground, a JAC-to-Python transpiler. Infrastructure builders, this one's yours.</div>
            </div>
            <div class="award-prize">$500 Claude Credits</div>
          </div>
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best Use of Lovable</div>
              <div class="award-desc">Use Lovable as a core part of your build. Best integration wins 3 months of Lovable free — that's real runway for your project post-hackathon.</div>
            </div>
            <div class="award-prize">3 Months Free</div>
          </div>
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best Use of Insforge (YC P26)</div>
              <div class="award-desc">Insforge is a YC-backed dev tool. Integrate it in a meaningful way and you're in the running for their prize package.</div>
            </div>
            <div class="award-prize">Credits + Merch Box</div>
          </div>
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best Use of Backboard</div>
              <div class="award-desc">Use Backboard as a core part of your product. Judged on how central and creative the integration is.</div>
            </div>
            <div class="award-prize">1-Year Subscription</div>
          </div>
          <div class="award-item">
            <div class="award-icon"></div>
            <div class="award-body">
              <div class="award-name">Best Startup Idea</div>
              <div class="award-desc">Judged on market potential, clarity of the problem, and uniqueness of the solution. This isn't about code quality. It's about the idea. Winner gets a fast-track interview to SH1P.</div>
            </div>
            <div class="award-prize">Fast-Track SH1P Interview</div>
          </div>
        </div>
      </div>

      <!-- CONTENT TRACK -->
      <div class="section">
        <div class="section-label">// Content &amp; Viral Track</div>
        <div class="section-title">Build in Public.</div>
        <p class="section-desc">These prizes are judged within one week of the event. Document what you built, how you built it, and why it matters. $100 per category, anyone can enter.</p>

        <div class="content-grid">
          <div class="content-card">
            <div class="content-platform">Best Instagram Post</div>
            <div class="content-detail">Most engaging, creative post about your JacHacks experience or project. Reels count. Carousels count. Make it shareable.</div>
            <div class="content-prize">$100</div>
          </div>
          <div class="content-card">
            <div class="content-platform">Best LinkedIn / X Post</div>
            <div class="content-detail">Best thought-leadership post, technical breakdown, or story about what you built. Engagement and quality both matter.</div>
            <div class="content-prize">$100</div>
          </div>
          <div class="content-card">
            <div class="content-platform">Best Technical Blog</div>
            <div class="content-detail">Deep-dive writeup on what you built, the tech decisions you made, and what you learned. Published anywhere (Medium, Substack, personal site).</div>
            <div class="content-prize">$100</div>
          </div>
          <div class="content-card">
            <div class="content-platform">Best YouTube Video</div>
            <div class="content-detail">Demo video, build vlog, or explainer about your project. Judged on clarity, production, and how viral it goes within the week.</div>
            <div class="content-prize">$100</div>
          </div>
        </div>
      </div>

      <!-- JUDGING -->
      <div class="section">
        <div class="section-label">// Judging Criteria</div>
        <div class="section-title">How We Judge.</div>
        <p class="section-desc">Every project is evaluated across these four dimensions. You have 3 minutes to present. Make them count.</p>

        <div class="criteria-grid">
          <div class="criteria-card">
            <div class="criteria-num">35%</div>
            <div class="criteria-label">Technical Depth</div>
            <div class="criteria-desc">How well does the code work? How creative is the architecture?</div>
          </div>
          <div class="criteria-card">
            <div class="criteria-num">30%</div>
            <div class="criteria-label">JAC Integration</div>
            <div class="criteria-desc">How deeply and effectively is JAC used as the backbone?</div>
          </div>
          <div class="criteria-card">
            <div class="criteria-num">20%</div>
            <div class="criteria-label">Real-World Impact</div>
            <div class="criteria-desc">Does this solve a real problem? Would anyone actually use it?</div>
          </div>
          <div class="criteria-card criteria-span-1">
            <div class="criteria-num">15%</div>
            <div class="criteria-label">Presentation</div>
            <div class="criteria-desc">Can you clearly explain what you built and why it matters?</div>
          </div>
          <div class="criteria-card criteria-pro-tip">
            <div>
              <div class="pro-tip-title">Pro tip</div>
              <div class="pro-tip-body">A polished demo beats a verbose explanation every time. Show, don't tell. Have something live and working before you get on stage.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- RULES -->
      <div class="section">
        <div class="section-label">// Rules</div>
        <div class="section-title">Keep It Fair.</div>
        <p class="section-desc">Simple rules. Follow them.</p>

        <div class="rules-list">
          <div class="rule-item">
            <div class="rule-num">01</div>
            <div class="rule-text">Teams can have up to 4 members. Solo and duo entries are welcome.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">02</div>
            <div class="rule-text">All code must be written during the hackathon. No pre-built projects. Starting from a blank slate is the point.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">03</div>
            <div class="rule-text">Open source libraries, APIs, and frameworks are all fair game. Use every tool available to you.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">04</div>
            <div class="rule-text">Your project must use JAC in a meaningful, non-trivial way. Bolting it on at the end doesn't count.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">05</div>
            <div class="rule-text">Submit to Devpost before 11:00 AM on Sunday. No extensions. No exceptions.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">06</div>
            <div class="rule-text">Be kind. Be collaborative. This event is a community. Act like it.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="footer">
      <div class="footer-left">Jac<span>Hacks</span> 2026</div>
      <div class="footer-info">
        U-M NORTH CAMPUS · ANN ARBOR, MI<br />
        APRIL 4–5, 2026 · LANG://JAC_REQUIRED<br />
        FREE TO ATTEND · $10K+ IN PRIZES
      </div>
    </div>

    <script>
      const nav = document.getElementById('main-nav')!;
      window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60));
      const hbg = document.getElementById('hamburger')!;
      const mm = document.getElementById('mobile-menu')!;
      hbg.addEventListener('click', () => {
        hbg.classList.toggle('open');
        mm.classList.toggle('open');
      });
      mm.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
          hbg.classList.remove('open');
          mm.classList.remove('open');
        })
      );
    </script>

    <style is:global>
      /* Top safe-area / padding behind fixed nav: match black hero (not white) */
      html:has(.schedule-page) {
        background-color: #0d0d0d;
      }

      /* Site nav (aligned with homepage) */
      .schedule-page {
        --bg: #07060a;
        --text: #e4e4e7;
        --muted: #52525b;
        --light: #a1a1aa;
        --primary: #f97316;
        --pl: #fb923c;
        --font: 'Inter', sans-serif;
        --display: 'Rajdhani', sans-serif;
        --mono: 'JetBrains Mono', monospace;
        padding-top: 0;
      }
      .schedule-page #main-nav {
        position: fixed;
        top: 1.25rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
        width: min(860px, calc(100% - 2.5rem));
        transition:
          width 0.6s cubic-bezier(0.4, 0, 0.2, 1),
          top 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .schedule-page #main-nav.scrolled {
        width: min(1100px, calc(100% - 1.5rem));
        top: 0.75rem;
      }
      .schedule-page .nav-inner {
        background: rgba(7, 6, 10, 0.92);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 0 0.6rem 0 1.25rem;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        overflow: hidden;
        transition:
          background 0.35s,
          border-color 0.35s,
          box-shadow 0.35s;
      }
      .schedule-page #main-nav.scrolled .nav-inner {
        border-color: rgba(249, 115, 22, 0.22);
        box-shadow:
          0 8px 40px rgba(0, 0, 0, 0.45),
          0 0 60px rgba(249, 115, 22, 0.06);
      }
      .schedule-page .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
        text-decoration: none;
        color: inherit;
      }
      .schedule-page .logo-img {
        width: 24px;
        height: 24px;
        object-fit: contain;
      }
      .schedule-page .logo-text {
        font-family: var(--display);
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.05em;
        color: #fff;
      }
      .schedule-page .logo-accent {
        color: var(--primary);
      }
      .schedule-page .nav-links {
        display: flex;
        gap: 1.5rem;
      }
      .schedule-page .nav-link {
        font-family: var(--mono);
        font-size: 0.63rem;
        color: var(--muted);
        letter-spacing: 0.1em;
        transition: color 0.2s;
        position: relative;
        white-space: nowrap;
        text-decoration: none;
      }
      .schedule-page .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--primary);
        transition: width 0.2s;
      }
      .schedule-page .nav-link:hover {
        color: var(--primary);
      }
      .schedule-page .nav-link:hover::after {
        width: 100%;
      }
      .schedule-page .nav-link-active {
        color: var(--primary);
      }
      .schedule-page .nav-link-active::after {
        width: 100%;
      }
      .schedule-page .nav-cta {
        font-family: var(--display);
        font-weight: 700;
        font-size: 0.78rem;
        letter-spacing: 0.1em;
        color: #000;
        background: var(--primary);
        padding: 0.35rem 1.1rem;
        border-radius: 100px;
        white-space: nowrap;
        flex-shrink: 0;
        transition: all 0.2s;
        box-shadow: 0 0 18px rgba(249, 115, 22, 0.35);
        text-decoration: none;
      }
      .schedule-page .nav-cta:hover {
        background: var(--pl);
        box-shadow: 0 0 30px rgba(249, 115, 22, 0.6);
        color: #000;
      }
      .schedule-page .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        flex-shrink: 0;
      }
      .schedule-page .hamburger span {
        display: block;
        width: 20px;
        height: 2px;
        background: var(--text);
        transition: all 0.25s;
        border-radius: 2px;
      }
      .schedule-page .hamburger.open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .schedule-page .hamburger.open span:nth-child(2) {
        opacity: 0;
      }
      .schedule-page .hamburger.open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
      .schedule-page .mobile-menu {
        display: none;
        position: fixed;
        top: calc(1.25rem + 58px);
        left: 50%;
        transform: translateX(-50%) translateY(-10px);
        width: min(800px, calc(100% - 2.5rem));
        background: rgba(7, 6, 10, 0.97);
        border: 1px solid rgba(249, 115, 22, 0.15);
        border-radius: 10px;
        padding: 1.5rem 1.75rem;
        z-index: 99;
        flex-direction: column;
        gap: 1.25rem;
        opacity: 0;
        transition:
          opacity 0.25s,
          transform 0.25s;
        pointer-events: none;
      }
      .schedule-page .mobile-menu.open {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        pointer-events: all;
      }
      .schedule-page .mobile-menu a {
        font-family: var(--mono);
        font-size: 0.85rem;
        color: var(--light);
        text-decoration: none;
      }
      .schedule-page .mobile-cta {
        color: var(--primary) !important;
        font-weight: 600;
      }
      @media (max-width: 768px) {
        .schedule-page .nav-links {
          display: none;
        }
        .schedule-page .hamburger {
          display: flex;
        }
        .schedule-page .mobile-menu {
          display: flex;
        }
      }

      /* Participant guide (reference design) */
      :root {
        --orange: #f4622a;
        --orange-light: #ff8a57;
        --orange-pale: #fff0ea;
        --black: #0d0d0d;
        --gray: #6b6b6b;
        --gray-light: #f5f5f5;
        --border: #e8e8e8;
        --white: #ffffff;
      }

      .schedule-page {
        font-family: 'DM Sans', sans-serif;
        color: var(--black);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
        padding-top: 5.5rem;
        /* Black under fixed nav; white below so guide sections match the design */
        background: linear-gradient(to bottom, #0d0d0d 0, #0d0d0d 5.5rem, #ffffff 5.5rem);
      }

      .schedule-page .guide-logo-link {
        display: flex;
        align-items: center;
        gap: 16px;
        text-decoration: none;
        color: inherit;
      }

      .schedule-page .guide-logo-img {
        width: 44px;
        height: 44px;
        object-fit: contain;
      }

      .schedule-page * {
        box-sizing: border-box;
      }

      .header {
        background: var(--black);
        padding: 60px 80px;
        position: relative;
        overflow: hidden;
      }

      .header::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(244, 98, 42, 0.25) 0%, transparent 70%);
      }

      .header-top {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 40px;
      }

      .logo-box {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .header .logo-text {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.5px;
      }

      .header .logo-text span {
        color: var(--orange);
      }

      .badge {
        margin-left: auto;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--orange);
        border: 1px solid rgba(244, 98, 42, 0.4);
        padding: 4px 12px;
        border-radius: 2px;
        letter-spacing: 1px;
      }

      .header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 64px;
        font-weight: 800;
        color: var(--white);
        line-height: 1;
        letter-spacing: -2px;
        margin-bottom: 16px;
      }

      .header h1 .highlight {
        color: var(--orange);
      }

      .header-sub {
        font-size: 17px;
        color: rgba(255, 255, 255, 0.55);
        font-weight: 300;
        margin-bottom: 40px;
        max-width: 520px;
      }

      .header-pills {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .pill {
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.7);
        padding: 8px 18px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.2px;
      }

      .pill.orange {
        background: var(--orange);
        border-color: var(--orange);
        color: white;
        font-weight: 600;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 48px;
      }

      .section {
        padding: 72px 0;
        border-bottom: 1px solid var(--border);
      }

      .section:last-child {
        border-bottom: none;
      }

      .section-label {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2.5px;
        color: var(--orange);
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -1px;
        color: var(--black);
        margin-bottom: 12px;
        line-height: 1.1;
      }

      .section-desc {
        color: var(--gray);
        font-size: 16px;
        max-width: 580px;
        margin-bottom: 44px;
        line-height: 1.65;
      }

      .day-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        margin-top: 40px;
      }

      .section .day-header:first-of-type {
        margin-top: 0;
      }

      .day-tag {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 2px;
        background: var(--orange);
        color: white;
        padding: 4px 10px;
        border-radius: 2px;
      }

      .day-title {
        font-family: 'Syne', sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--black);
      }

      .schedule-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .schedule-item {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 24px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
        align-items: start;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .schedule-item:last-child {
        border-bottom: none;
      }

      .s-time {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--gray);
        padding-top: 2px;
      }

      .s-content {
        display: flex;
        align-items: flex-start;
        gap: 12px;
      }

      .s-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border);
        margin-top: 6px;
        flex-shrink: 0;
      }

      .s-dot.orange {
        background: var(--orange);
      }
      .s-dot.green {
        background: #22c55e;
      }
      .s-dot.yellow {
        background: #f59e0b;
      }
      .s-dot.red {
        background: #ef4444;
      }

      .s-name {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--black);
        letter-spacing: -0.2px;
      }

      .s-name.orange {
        color: var(--orange);
      }

      .s-desc {
        font-size: 13px;
        color: var(--gray);
        margin-top: 2px;
      }

      .tracks-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 32px;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .track-card {
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 28px;
        position: relative;
        overflow: hidden;
        transition: border-color 0.2s;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .track-card:hover {
        border-color: var(--orange-light);
      }

      .track-card.flagship {
        border-color: var(--orange);
        background: linear-gradient(135deg, #fff 60%, #fff5f1 100%);
        grid-column: 1 / -1;
      }

      .track-card.flagship::before {
        content: 'FLAGSHIP TRACK';
        position: absolute;
        top: 20px;
        right: 20px;
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 2px;
        color: var(--orange);
        background: var(--orange-pale);
        padding: 4px 10px;
        border-radius: 2px;
      }

      .track-emoji {
        font-size: 28px;
        margin-bottom: 14px;
      }

      .track-name {
        font-family: 'Syne', sans-serif;
        font-size: 20px;
        font-weight: 800;
        color: var(--black);
        margin-bottom: 8px;
        letter-spacing: -0.5px;
      }

      .track-desc {
        font-size: 13.5px;
        color: var(--gray);
        line-height: 1.6;
        margin-bottom: 20px;
      }

      .track-prizes {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .prize-badge {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 6px;
      }

      .prize-badge.first {
        background: var(--orange);
        color: white;
      }

      .prize-badge.second {
        background: var(--orange-pale);
        color: var(--orange);
        border: 1px solid rgba(244, 98, 42, 0.2);
      }

      .prize-badge.sponsor {
        background: var(--gray-light);
        color: var(--gray);
      }

      .track-ideas {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }

      .track-ideas-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--gray);
        margin-bottom: 8px;
      }

      .ideas-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .idea-chip {
        font-size: 12px;
        background: var(--gray-light);
        color: var(--black);
        padding: 4px 10px;
        border-radius: 100px;
      }

      .awards-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .award-item {
        display: flex;
        align-items: flex-start;
        gap: 20px;
        padding: 20px 24px;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        transition: border-color 0.2s;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .award-item:hover {
        border-color: var(--orange-light);
      }

      .award-icon {
        font-size: 24px;
        width: 44px;
        text-align: center;
        flex-shrink: 0;
        padding-top: 2px;
      }

      .award-body {
        flex: 1;
      }

      .award-name {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: var(--black);
        margin-bottom: 4px;
      }

      .award-desc {
        font-size: 13px;
        color: var(--gray);
        line-height: 1.55;
      }

      .award-prize {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        color: var(--orange);
        white-space: nowrap;
        padding-top: 2px;
      }

      .content-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .content-card {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 20px 22px;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .content-platform {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .content-detail {
        font-size: 13px;
        color: var(--gray);
        margin-bottom: 12px;
        line-height: 1.5;
      }

      .content-prize {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        color: var(--orange);
        font-weight: 700;
      }

      .criteria-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
      }

      .criteria-card {
        background: var(--gray-light);
        border-radius: 10px;
        padding: 22px;
        text-align: center;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .criteria-num {
        font-family: 'Syne', sans-serif;
        font-size: 36px;
        font-weight: 800;
        color: var(--orange);
        line-height: 1;
        margin-bottom: 6px;
      }

      .criteria-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--black);
        margin-bottom: 4px;
      }

      .criteria-desc {
        font-size: 12px;
        color: var(--gray);
      }

      .criteria-span-1 {
        grid-column: 1 / 2;
      }

      .criteria-pro-tip {
        grid-column: 2 / 4;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .pro-tip-title {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 14px;
        margin-bottom: 4px;
        color: var(--black);
      }

      .pro-tip-body {
        font-size: 13px;
        color: var(--gray);
        line-height: 1.55;
      }

      .rules-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .rule-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .rule-item:last-child {
        border-bottom: none;
      }

      .rule-num {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--orange);
        width: 28px;
        flex-shrink: 0;
        padding-top: 1px;
      }

      .rule-text {
        font-size: 14.5px;
        color: var(--black);
        line-height: 1.55;
      }

      .footer {
        background: var(--black);
        padding: 48px 80px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 24px;
      }

      .footer-left {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: white;
        letter-spacing: -0.5px;
      }

      .footer-left span {
        color: var(--orange);
      }

      .footer-info {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.5px;
        line-height: 1.8;
        text-align: right;
      }

      .divider {
        height: 4px;
        background: linear-gradient(90deg, var(--orange) 0%, var(--orange-light) 50%, transparent 100%);
        margin-bottom: 0;
      }

      @media print {
        .schedule-page #main-nav,
        .schedule-page .mobile-menu,
        .schedule-page .hamburger {
          display: none !important;
        }
        .schedule-page {
          padding-top: 0;
        }
        .header {
          padding: 40px 48px;
        }
        .header h1 {
          font-size: 48px;
        }
        .section {
          padding: 48px 0;
        }
      }

      @media (max-width: 768px) {
        .header {
          padding: 40px 24px;
        }
        .header h1 {
          font-size: 42px;
        }
        .container {
          padding: 0 24px;
        }
        .schedule-item {
          grid-template-columns: 1fr;
          gap: 8px;
        }
        .tracks-grid {
          grid-template-columns: 1fr;
        }
        .content-grid {
          grid-template-columns: 1fr;
        }
        .criteria-grid {
          grid-template-columns: 1fr;
        }
        .criteria-span-1,
        .criteria-pro-tip {
          grid-column: auto;
        }
        .footer {
          padding: 36px 24px;
          flex-direction: column;
          text-align: center;
        }
        .footer-info {
          text-align: center;
        }
        .badge {
          display: none;
        }
      }
    </style>
  </body>
</html>
